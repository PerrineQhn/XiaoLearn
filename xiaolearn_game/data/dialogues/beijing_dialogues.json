{
  "region": "beijing",
  "npcs": [
    {
      "npc_id": "npc_palace_guard",
      "npc_name_cn": "卫兵",
      "npc_name_fr": "Garde Impérial",
      "portrait": "res://assets/portraits/guard.png",
      "dialogue_tree": {
        "start": {
          "lines": [
            {
              "cn": "你好！欢迎来北京！",
              "pinyin": "Nǐ hǎo! Huānyíng lái Běijīng!",
              "fr": "Bonjour ! Bienvenue à Pékin !",
              "audio": "dialogue_guard_001.ogg",
              "teaches": ["hsk1_001", "hsk1_027", "hsk1_026"]
            },
            {
              "cn": "我是故宫的卫兵。今天天气很好！",
              "pinyin": "Wǒ shì Gùgōng de wèibīng. Jīntiān tiānqì hěn hǎo!",
              "fr": "Je suis la garde de la Cité Interdite. Il fait beau aujourd'hui !",
              "audio": "dialogue_guard_002.ogg",
              "teaches": ["hsk1_004", "hsk1_008", "hsk1_033"]
            }
          ],
          "choices": [
            {
              "text_fr": "Bonjour ! Je suis ravi d'être à Beijing.",
              "text_cn": "你好！我很高兴来北京。",
              "next": "response_greeting"
            },
            {
              "text_fr": "Qu'est-ce que la Cité Interdite ?",
              "text_cn": "故宫是什么？",
              "next": "explain_gugong"
            }
          ]
        },
        "response_greeting": {
          "lines": [
            {
              "cn": "太好了！你是哪国人？",
              "pinyin": "Tài hǎo le! Nǐ shì nǎ guó rén?",
              "fr": "Parfait ! De quel pays venez-vous ?",
              "audio": "dialogue_guard_003.ogg",
              "teaches": ["hsk1_031"]
            }
          ],
          "choices": [
            {
              "text_fr": "Je suis français(e).",
              "text_cn": "我是法国人。",
              "next": "player_french",
              "teaches": ["hsk1_004", "hsk1_008"]
            },
            {
              "text_fr": "Je suis étudiant(e) en chinois.",
              "text_cn": "我是学汉语的学生。",
              "next": "player_student",
              "teaches": ["hsk1_039", "hsk1_038"]
            }
          ]
        },
        "player_french": {
          "lines": [
            {
              "cn": "法国！很好！法国人很喜欢中国。",
              "pinyin": "Fǎguó! Hěn hǎo! Fǎguó rén hěn xǐ huān Zhōngguó.",
              "fr": "La France ! Très bien ! Les Français aiment beaucoup la Chine.",
              "audio": "dialogue_guard_004.ogg",
              "teaches": ["hsk1_031", "hsk1_032", "hsk1_025"]
            },
            {
              "cn": "祝你在北京学习愉快！再见！",
              "pinyin": "Zhù nǐ zài Běijīng xuéxí yúkuài! Zài jiàn!",
              "fr": "Bon apprentissage à Beijing ! Au revoir !",
              "audio": "dialogue_guard_005.ogg",
              "teaches": ["hsk1_003", "hsk1_038"]
            }
          ],
          "next": "end"
        },
        "player_student": {
          "lines": [
            {
              "cn": "学汉语很好！汉语很有用。",
              "pinyin": "Xué Hànyǔ hěn hǎo! Hànyǔ hěn yǒuyòng.",
              "fr": "Apprendre le mandarin, c'est très bien ! Le mandarin est très utile.",
              "audio": "dialogue_guard_006.ogg",
              "teaches": ["hsk1_039", "hsk1_031"]
            },
            {
              "cn": "加油！再见！",
              "pinyin": "Jiā yóu! Zài jiàn!",
              "fr": "Courage ! Au revoir !",
              "audio": "dialogue_guard_007.ogg",
              "teaches": ["hsk1_003"]
            }
          ],
          "next": "end"
        },
        "explain_gugong": {
          "lines": [
            {
              "cn": "故宫是中国古代皇帝住的地方。",
              "pinyin": "Gùgōng shì Zhōngguó gǔdài huángdì zhù de dìfāng.",
              "fr": "La Cité Interdite est l'endroit où vivaient les empereurs de la Chine ancienne.",
              "audio": "dialogue_guard_008.ogg",
              "teaches": ["hsk1_025", "hsk1_008"]
            },
            {
              "cn": "很大！里面有九千多个房间！",
              "pinyin": "Hěn dà! Lǐmiàn yǒu jiǔ qiān duō gè fángjiān!",
              "fr": "Très grand ! Il y a plus de neuf mille pièces à l'intérieur !",
              "audio": "dialogue_guard_009.ogg",
              "teaches": ["hsk1_022", "hsk1_010", "hsk1_020"]
            }
          ],
          "choices": [
            {
              "text_fr": "Impressionnant ! Merci.",
              "text_cn": "太厉害了！谢谢！",
              "next": "end_thanks",
              "teaches": ["hsk1_002"]
            }
          ]
        },
        "end_thanks": {
          "lines": [
            {
              "cn": "不客气！好好游览！",
              "pinyin": "Bù kèqì! Hǎohǎo yóulǎn!",
              "fr": "De rien ! Profitez bien de votre visite !",
              "audio": "dialogue_guard_010.ogg",
              "teaches": ["hsk1_009", "hsk1_031"]
            }
          ],
          "next": "end"
        },
        "completed": {
          "lines": [
            {
              "cn": "欢迎再来！北京很大，慢慢看！",
              "pinyin": "Huānyíng zài lái! Běijīng hěn dà, màn màn kàn!",
              "fr": "Revenez quand vous voulez ! Beijing est grande, prenez le temps de la découvrir !",
              "audio": "dialogue_guard_011.ogg"
            }
          ],
          "next": "end"
        }
      }
    },
    {
      "npc_id": "npc_tea_merchant",
      "npc_name_cn": "茶商",
      "npc_name_fr": "Marchand de thé",
      "portrait": "res://assets/portraits/merchant.png",
      "dialogue_tree": {
        "start": {
          "lines": [
            {
              "cn": "你好！买茶吗？我这里有很多好茶！",
              "pinyin": "Nǐ hǎo! Mǎi chá ma? Wǒ zhèlǐ yǒu hěn duō hǎo chá!",
              "fr": "Bonjour ! Vous voulez du thé ? J'ai de très bons thés ici !",
              "audio": "dialogue_merchant_001.ogg",
              "teaches": ["hsk1_001", "hsk1_010", "hsk1_031"]
            }
          ],
          "choices": [
            {
              "text_fr": "Combien coûte une tasse ?",
              "text_cn": "一杯多少钱？",
              "next": "price_question"
            },
            {
              "text_fr": "Quels types de thé avez-vous ?",
              "text_cn": "你有什么茶？",
              "next": "tea_types"
            },
            {
              "text_fr": "Non merci, au revoir.",
              "text_cn": "不，谢谢。再见！",
              "next": "end_polite",
              "teaches": ["hsk1_009", "hsk1_002", "hsk1_003"]
            }
          ]
        },
        "price_question": {
          "lines": [
            {
              "cn": "一杯茶十块钱。",
              "pinyin": "Yī bēi chá shí kuài qián.",
              "fr": "Une tasse de thé coûte dix yuans.",
              "audio": "dialogue_merchant_002.ogg",
              "teaches": ["hsk1_012", "hsk1_021"]
            },
            {
              "cn": "三杯二十五块，很划算！",
              "pinyin": "Sān bēi èrshíwǔ kuài, hěn huásuàn!",
              "fr": "Trois tasses pour vingt-cinq yuans, c'est très avantageux !",
              "audio": "dialogue_merchant_003.ogg",
              "teaches": ["hsk1_014", "hsk1_013"]
            }
          ],
          "type": "quiz",
          "quiz_data": {
            "quiz_id": "quiz_numbers_001",
            "question_word_id": "hsk1_021",
            "question_type": "cn_to_fr",
            "question_cn": "十",
            "question_pinyin": "shí",
            "options": []
          },
          "on_correct": "quiz_correct_numbers",
          "on_wrong": "quiz_wrong_numbers"
        },
        "quiz_correct_numbers": {
          "lines": [
            {
              "cn": "对！你的汉语很好！",
              "pinyin": "Duì! Nǐ de Hànyǔ hěn hǎo!",
              "fr": "Exact ! Votre chinois est très bon !",
              "audio": "dialogue_merchant_004.ogg",
              "teaches": ["hsk1_039", "hsk1_031"]
            }
          ],
          "choices": [
            {
              "text_fr": "Je voudrais deux tasses s'il vous plaît.",
              "text_cn": "我要两杯，谢谢！",
              "next": "buy_tea",
              "teaches": ["hsk1_013", "hsk1_002"]
            }
          ]
        },
        "quiz_wrong_numbers": {
          "lines": [
            {
              "cn": "不对。十 是 shí，是十块钱。",
              "pinyin": "Bú duì. Shí shì shí, shì shí kuài qián.",
              "fr": "Pas tout à fait. 十 se dit 'shí', et ça veut dire dix yuans.",
              "audio": "dialogue_merchant_005.ogg",
              "teaches": ["hsk1_009", "hsk1_021"]
            }
          ],
          "choices": [
            {
              "text_fr": "Ah je comprends maintenant, merci !",
              "text_cn": "啊，我明白了，谢谢！",
              "next": "buy_tea"
            }
          ]
        },
        "buy_tea": {
          "lines": [
            {
              "cn": "好！请坐，我给你拿来。",
              "pinyin": "Hǎo! Qǐng zuò, wǒ gěi nǐ ná lái.",
              "fr": "D'accord ! Asseyez-vous, je vous l'apporte.",
              "audio": "dialogue_merchant_006.ogg",
              "teaches": ["hsk1_031"]
            }
          ],
          "next": "end"
        },
        "tea_types": {
          "lines": [
            {
              "cn": "我有龙井、普洱、茉莉花茶。",
              "pinyin": "Wǒ yǒu Lóngjǐng, Pǔ'ěr, Mòlìhuā chá.",
              "fr": "J'ai du Longjing, du Pu'er, et du thé au jasmin.",
              "audio": "dialogue_merchant_007.ogg",
              "teaches": ["hsk1_010"]
            },
            {
              "cn": "你喜欢哪种茶？",
              "pinyin": "Nǐ xǐ huān nǎ zhǒng chá?",
              "fr": "Quel type de thé aimez-vous ?",
              "audio": "dialogue_merchant_008.ogg",
              "teaches": ["hsk1_032"]
            }
          ],
          "choices": [
            {
              "text_fr": "Je voudrais du Longjing.",
              "text_cn": "我要龙井。",
              "next": "buy_tea"
            },
            {
              "text_fr": "Du thé au jasmin, s'il vous plaît.",
              "text_cn": "茉莉花茶，谢谢。",
              "next": "buy_tea",
              "teaches": ["hsk1_002"]
            }
          ]
        },
        "end_polite": {
          "lines": [
            {
              "cn": "没关系！再见！",
              "pinyin": "Méi guānxi! Zài jiàn!",
              "fr": "Pas de problème ! Au revoir !",
              "audio": "dialogue_merchant_009.ogg",
              "teaches": ["hsk1_003"]
            }
          ],
          "next": "end"
        },
        "completed": {
          "lines": [
            {
              "cn": "又来了！今天喝什么茶？",
              "pinyin": "Yòu lái le! Jīntiān hē shénme chá?",
              "fr": "Vous revoilà ! Quel thé aujourd'hui ?",
              "audio": "dialogue_merchant_010.ogg",
              "teaches": ["hsk1_033", "hsk1_030"]
            }
          ],
          "choices": [
            {
              "text_fr": "Du Longjing s'il vous plaît !",
              "text_cn": "龙井，谢谢！",
              "next": "buy_tea"
            }
          ]
        }
      }
    },
    {
      "npc_id": "npc_student",
      "npc_name_cn": "学生",
      "npc_name_fr": "Étudiant(e)",
      "portrait": "res://assets/portraits/student.png",
      "dialogue_tree": {
        "start": {
          "lines": [
            {
              "cn": "嗨！你好！我叫小雨。你叫什么名字？",
              "pinyin": "Hāi! Nǐ hǎo! Wǒ jiào Xiǎo Yǔ. Nǐ jiào shénme míngzì?",
              "fr": "Hé ! Bonjour ! Je m'appelle Xiao Yu. Comment vous appelez-vous ?",
              "audio": "dialogue_student_001.ogg",
              "teaches": ["hsk1_001", "hsk1_004", "hsk1_005"]
            }
          ],
          "choices": [
            {
              "text_fr": "Je m'appelle [votre nom]. Enchanté(e) !",
              "text_cn": "我叫……很高兴认识你！",
              "next": "intro_exchange",
              "teaches": ["hsk1_004"]
            },
            {
              "text_fr": "Tu étudies ici ?",
              "text_cn": "你在这里学习吗？",
