        "quiz_intro_correct": {
          "lines": [
            {
              "cn": "棒极了！你真的很聪明！我们是朋友了！",
              "pinyin": "Bàng jí le! Nǐ zhēn de hěn cōngmíng! Wǒmen shì péngyǒu le!",
              "fr": "Excellent ! Vous êtes vraiment intelligent(e) ! Nous sommes amis maintenant !",
