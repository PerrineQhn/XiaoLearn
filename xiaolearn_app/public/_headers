# Cloudflare Pages — politique de cache HTTP
# -------------------------------------------
# Problème : sans cette config, le navigateur peut cacher index.html pendant
# des heures/jours et les utilisateurs ne voient pas les nouveaux builds. Vite
# hash les noms de chunks JS/CSS (ils sont donc safe à cacher fort) mais
# index.html lui-même doit toujours être vérifié pour récupérer les hash
# mis à jour.

# index.html (et toute page HTML servie via SPA fallback) : pas de cache.
# On revalide systématiquement pour récupérer les derniers hash de chunks.
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/
  Cache-Control: no-cache, no-store, must-revalidate

# Tous les paths SPA (fallback /index.html) — pas de cache HTML
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Assets buildés (JS/CSS hashés par Vite) — cache fort 1 an, immutables
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Manifeste PWA — revalidation à chaque visite
/manifest.webmanifest
  Cache-Control: no-cache

# Icônes, logos, audio — cache modéré (1 semaine), peuvent être versionnés
/icons/*
  Cache-Control: public, max-age=604800
/logos/*
  Cache-Control: public, max-age=604800
/profs/*
  Cache-Control: public, max-age=604800
