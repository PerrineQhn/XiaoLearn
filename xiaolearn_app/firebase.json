{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "hosting": [
    {
      "site": "xiaolearn-pay",
      "public": "public-pay",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/api/checkout",
          "function": {
            "functionId": "createCheckout",
            "region": "europe-west1"
          }
        },
        {
          "source": "/api/portal",
          "function": {
            "functionId": "createPortal",
            "region": "europe-west1"
          }
        },
        {
          "source": "/api/webhook",
          "function": {
            "functionId": "stripeWebhook",
            "region": "europe-west1"
          }
        }
      ],
      "headers": [
        {
          "source": "/**",
          "headers": [
            {
              "key": "X-Frame-Options",
              "value": "DENY"
            }
          ]
        }
      ]
    }
  ]
}

