rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isCPlayerOwner() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/app_config/cplayer_owner)
        && get(/databases/$(database)/documents/app_config/cplayer_owner).data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /pending_entitlements/{email} {
      allow read, update: if request.auth != null && request.auth.token.email == email;
      allow create, delete: if false;
    }

    match /app_config/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && docId == "cplayer_owner"
        && !exists(/databases/$(database)/documents/app_config/cplayer_owner)
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn()
        && docId == "cplayer_owner"
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if false;
    }

    match /cplayer_lyrics/{videoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.videoId == videoId
        && request.resource.data.lines is list
        && request.resource.data.reviewed == false
        && request.resource.data.source in ["ai-generated", "runtime-cache"];
      allow update: if isCPlayerOwner()
        && request.resource.data.videoId == videoId
        && request.resource.data.lines is list;
      allow delete: if false;
    }

    // ========================================================================
    //  COMMUNAUTÉ (task #44) — publicProfiles / battleQueue / battleMatches
    //  Voir /FIRESTORE_RULES.md pour la doc humaine.
    // ========================================================================

    match /publicProfiles/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow delete: if false;
    }

    match /battleQueue/{uid} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.matchId == null;
      allow delete: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (
        // cas 1 : le propriétaire met à jour ses propres champs
        request.auth.uid == uid
        ||
        // cas 2 : un pair pose le matchId pendant la transaction de matching
        (
          request.resource.data.uid == resource.data.uid
          && request.resource.data.queuedAt == resource.data.queuedAt
          && resource.data.matchId == null
          && request.resource.data.matchId is string
        )
      );
    }

    match /battleMatches/{matchId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.p1.uid
        || request.auth.uid == resource.data.p2.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.p1.uid == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.p1Answers.size() == 0
        && request.resource.data.p2Answers.size() == 0;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.p1.uid
        || request.auth.uid == resource.data.p2.uid
      );
      allow delete: if false;
    }

    // ========================================================================
    //  EMAIL PREFERENCES (task #66) — lecture/écriture privée par user.
    //  Une Cloud Function lira ce doc côté serveur pour filtrer les envois.
    // ========================================================================

    match /emailPrefs/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ========================================================================
    //  BLOG VIEWS — compteur public de vues d'articles
    //  Accessible anonymement (le blog est public). Incrément autorisé
    //  seulement de +1 par write, pour empêcher les boosts massifs.
    // ========================================================================

    match /blog_views/{slug} {
      allow read: if true;

      // Création : count == 0 (sera incrémenté juste après par un autre write)
      allow create: if request.resource.data.count == 0
        && request.resource.data.slug == slug;

      // Update : seul `count` peut bouger, et uniquement de +1.
      // Le fieldTransform `increment(1)` côté client passe par cette règle.
      allow update: if request.resource.data.count == resource.data.count + 1
        && request.resource.data.slug == resource.data.slug;

      allow delete: if false;
    }

    // ========================================================================
    //  COMMUNITY IDEAS (task #4) — propositions de la communauté.
    //  Lecture publique pour utilisateurs connectés. Écriture restreinte :
    //  l'auteur crée, l'auteur peut modifier title/description tant que le
    //  status reste 'pending'. Le status est piloté par admin (console).
    // ========================================================================

    match /community_ideas/{ideaId} {
      allow read: if isSignedIn();

      // Création par n'importe quel user connecté, avec authorId == auth.uid
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 1500
        && request.resource.data.status == 'pending'
        && request.resource.data.voteCount == 0;

      // Update :
      //   - L'auteur peut éditer title/description/category si status == 'pending'
      //   - N'importe quel user peut bumper voteCount (uniquement de ±1) — la
      //     vraie validation se fait via la transaction côté sous-collection.
      allow update: if isSignedIn() && (
        // Cas 1 : l'auteur édite les champs textuels
        (
          resource.data.authorId == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.status == resource.data.status
          && request.resource.data.voteCount == resource.data.voteCount
        )
        ||
        // Cas 2 : mise à jour du voteCount uniquement, par n'importe qui
        (
          request.resource.data.authorId == resource.data.authorId
          && request.resource.data.title == resource.data.title
          && request.resource.data.description == resource.data.description
          && request.resource.data.category == resource.data.category
          && request.resource.data.status == resource.data.status
          && request.resource.data.voteCount is number
          && (
            request.resource.data.voteCount == resource.data.voteCount + 1
            || request.resource.data.voteCount == resource.data.voteCount - 1
          )
        )
      );

      allow delete: if false;

      // Sous-collection votes : un vote par user, idempotent
      match /votes/{uid} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == uid;
        allow delete: if isSignedIn() && request.auth.uid == uid;
        allow update: if false;
      }
    }

    // ========================================================================
    //  COMMUNITY ROADMAP (task #4) — jalons curatés en lecture seule.
    // ========================================================================

    match /community_roadmap/{milestoneId} {
      allow read: if isSignedIn();
      allow write: if false; // admin via console uniquement
    }

    // ========================================================================
    //  CONVERSATIONS (task #4) — fils 1-1 entre deux apprenants.
    //  convId = sort([uidA, uidB]).join('_').
    // ========================================================================

    match /conversations/{convId} {
      // GET : un utilisateur connecté peut lire un doc qui le concerne, OU
      // un doc inexistant (cas du `getDoc()` préalable dans
      // `openOrCreateConversation` qui vérifie l'existence avant write —
      // sans cette branche, la rule denied même pour soi-même).
      allow get: if isSignedIn() && (
        resource == null ||
        request.auth.uid in resource.data.participantIds
      );
      // LIST : autorisée pour les listeners qui filtrent côté client par
      // `where('participantIds', 'array-contains', uid)`. Chaque doc retourné
      // est re-vérifié par la règle `get` ci-dessus.
      allow list: if isSignedIn();

      // Création : un participant doit être l'utilisateur courant
      allow create: if isSignedIn()
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() == 2
        && request.auth.uid in request.resource.data.participantIds;

      // Update : les deux participants peuvent modifier (lastMessage, unreadCount).
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participantIds
        && request.resource.data.participantIds == resource.data.participantIds;

      allow delete: if false;

      // Messages
      match /messages/{msgId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;

        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;

        // Update : autorisé seulement pour mettre à jour `readBy` (mark-as-read).
        // On garde tous les autres champs intacts.
        allow update: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds
          && request.resource.data.text == resource.data.text
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.sentAt == resource.data.sentAt;

        allow delete: if false;
      }
    }
  }
}
