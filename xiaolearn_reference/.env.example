# Configuration Firebase pour le compteur de vues blog
# ----------------------------------------------------------------------
# Ces variables doivent être préfixées PUBLIC_ pour être exposées au
# client (build Astro). Les valeurs viennent du projet Firebase de l'app
# XiaoLearn (xiaolearn-db9e6).
#
# À configurer en local : copier en .env et remplir les valeurs.
# À configurer en prod  : Cloudflare Pages → Settings → Environment vars.

PUBLIC_FIREBASE_PROJECT_ID=xiaolearn-db9e6
PUBLIC_FIREBASE_API_KEY=ta-cle-api-publique
