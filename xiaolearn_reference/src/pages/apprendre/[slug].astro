---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AudioButton from '../../components/AudioButton.astro';
import { LEARNING_CONTENT, getLearningContent } from '../../data/learning-content';

export async function getStaticPaths() {
  return LEARNING_CONTENT
    .filter((c) => c.status === 'published')
    .map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const content = getLearningContent(slug ?? '');
if (!content || content.status !== 'published') {
  return Astro.redirect('/apprendre');
}

const formatDate = (iso: string) => {
  try {
    const d = new Date(iso);
    return d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch {
    return iso;
  }
};

const canonicalUrl = `https://xiaolearn.com/apprendre/${content.slug}`;
const totalEntries = content.sections?.reduce((acc, s) => acc + s.entries.length, 0) ?? 0;
const isGuide = content.type === 'guide';
const isListe = content.type === 'liste';
---

<BaseLayout
  title={content.title}
  description={content.shortDescription}
  canonical={canonicalUrl}
>
  <article class={`learn-article learn-article--${content.type}`}>
    <header class="article-header container">
      <Breadcrumb
        items={[
          { label: 'Accueil', href: '/' },
          { label: 'Apprendre', href: '/apprendre' },
          { label: content.title }
        ]}
        locale="fr"
      />
      <p class="article-kicker">
        {isGuide ? 'GUIDE' : 'LISTE'} · {content.kicker}
      </p>
      <h1 class="article-title">{content.title}</h1>
      <p class="article-lead">{content.longDescription ?? content.shortDescription}</p>
      <p class="article-updated">Mis à jour le {formatDate(content.updatedAt)}</p>

      {/* Featured card pour les guides (gros hanzi + audio) */}
      {isGuide && content.featuredHanzi && (
        <div class="featured-card">
          <span class="featured-hanzi">{content.featuredHanzi}</span>
          <div class="featured-meta">
            <AudioButton hanzi={content.featuredHanzi} size="sm" />
            {content.featuredPinyin && <span class="featured-pinyin">{content.featuredPinyin}</span>}
          </div>
          <p class="featured-translation">{content.shortDescription}</p>
        </div>
      )}

      {/* Sommaire pour les listes */}
      {isListe && content.sections && content.sections.length > 1 && (
        <aside class="article-toc">
          <header>
            <span class="toc-label">SOMMAIRE</span>
            <span class="toc-count">{totalEntries} entrées</span>
          </header>
          <ol>
            {content.sections.map((s) => (
              <li>
                <a href={`#${s.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>
                  <span>{s.title}</span>
                  <span class="toc-num">{s.entries.length}</span>
                </a>
              </li>
            ))}
          </ol>
        </aside>
      )}
    </header>

    <div class="article-body container">
      {content.sections?.map((s) => {
        const anchor = s.title.toLowerCase().replace(/[^a-z0-9]+/g, '-');
        return (
          <section class="article-section" id={anchor}>
            <header class="section-header-block">
              <span class="section-bar" aria-hidden="true"></span>
              <h2>{s.title}</h2>
              <span class="section-count">{s.entries.length}</span>
            </header>
            {s.description && <p class="section-description">{s.description}</p>}
            <div class="entry-list">
              {s.entries.map((e) => (
                <div class="entry-row">
                  <span class="entry-hanzi">{e.hanzi}</span>
                  <span class="entry-pinyin">{e.pinyin}</span>
                  <span class="entry-translation">
                    {e.translationFr}
                    {e.gloss && <span class="entry-gloss"> ({e.gloss})</span>}
                  </span>
                  <span class="entry-actions">
                    <AudioButton hanzi={e.hanzi} size="sm" />
                  </span>
                </div>
              ))}
            </div>
          </section>
        );
      })}
    </div>

    <section class="cta-section container">
      <div class="cta-card">
        <h2>Continue d'apprendre le mandarin</h2>
        <p>
          Crée ton compte gratuit pour ajouter ces mots à tes flashcards
          et progresser jour après jour.
        </p>
        <div class="cta-buttons">
          <a href="https://app.xiaolearn.com" class="btn btn-primary">Créer mon compte gratuit</a>
          <a href="/dictionnaire" class="btn btn-ghost">Explorer le dictionnaire →</a>
        </div>
        <p class="cta-foot">Gratuit pour toujours. Aucune carte requise.</p>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .learn-article {
    padding-bottom: var(--spacing-2xl);
  }

  .article-header {
    padding-top: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
    max-width: 760px;
  }
  .article-kicker {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin: var(--spacing-md) 0 var(--spacing-sm);
  }
  .article-title {
    margin: 0 0 var(--spacing-md);
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    line-height: 1.2;
  }
  .article-lead {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.65;
    margin: 0 0 var(--spacing-md);
  }
  .article-updated {
    color: var(--text-tertiary);
    font-size: 0.85rem;
    margin: 0 0 var(--spacing-xl);
  }

  /* Featured card (guides) */
  .featured-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: var(--spacing-xl);
    row-gap: var(--spacing-sm);
    align-items: center;
  }
  .featured-hanzi {
    grid-row: 1 / span 2;
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1;
  }
  .featured-meta {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
  }
  .featured-pinyin {
    font-style: italic;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .featured-translation {
    margin: 0;
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* Sommaire (listes) */
  .article-toc {
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: var(--spacing-md) var(--spacing-lg);
  }
  .article-toc header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-sm);
  }
  .toc-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--text-tertiary);
  }
  .toc-count {
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }
  .article-toc ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xs) var(--spacing-lg);
  }
  .article-toc a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.35rem 0;
    color: var(--text-primary);
    font-size: 0.9rem;
    border-bottom: 1px dotted transparent;
  }
  .article-toc a:hover { border-bottom-color: var(--border-medium); }
  .toc-num { color: var(--text-tertiary); font-size: 0.8rem; }

  /* Article body */
  .article-body { max-width: 760px; padding-top: var(--spacing-xl); }

  .article-section {
    margin-bottom: var(--spacing-2xl);
    scroll-margin-top: 100px;
  }
  .section-header-block {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }
  .section-bar {
    width: 24px;
    height: 1px;
    background: var(--text-secondary);
    margin-right: var(--spacing-xs);
  }
  .section-header-block h2 {
    margin: 0;
    font-size: 1.25rem;
    flex: 1;
  }
  .section-count {
    color: var(--text-tertiary);
    font-size: 0.85rem;
  }
  .section-description {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 var(--spacing-md);
  }

  /* Entries */
  .entry-list {
    border-top: 1px solid var(--border-light);
  }
  .entry-row {
    display: grid;
    grid-template-columns: minmax(80px, auto) minmax(80px, auto) 1fr auto;
    gap: var(--spacing-md);
    align-items: center;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--border-light);
  }
  .entry-hanzi {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
  }
  .entry-pinyin {
    font-style: italic;
    color: var(--text-tertiary);
    font-size: 0.9rem;
    white-space: nowrap;
  }
  .entry-translation {
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .entry-gloss {
    color: var(--text-tertiary);
    font-size: 0.85rem;
    font-style: italic;
  }
  .entry-actions {
    display: inline-flex;
    align-items: center;
  }

  /* CTA */
  .cta-section { padding-top: var(--spacing-xl); max-width: 760px; }
  .cta-card {
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: var(--spacing-2xl);
    text-align: center;
  }
  .cta-card h2 { margin: 0 0 var(--spacing-sm); font-size: 1.3rem; }
  .cta-card p { color: var(--text-secondary); margin: 0 auto var(--spacing-lg); max-width: 52ch; }
  .cta-buttons { display: inline-flex; gap: var(--spacing-md); flex-wrap: wrap; justify-content: center; margin-bottom: var(--spacing-sm); }
  .cta-foot { font-size: 0.85rem; color: var(--text-tertiary); margin: 0; }

  /* Responsive */
  @media (max-width: 820px) {
    .featured-card { padding: var(--spacing-lg); column-gap: var(--spacing-md); }
    .featured-hanzi { font-size: 2.4rem; }
    .article-toc ol { grid-template-columns: 1fr; }
    .entry-row {
      grid-template-columns: minmax(70px, auto) 1fr auto;
      gap: var(--spacing-sm);
      row-gap: 2px;
    }
    .entry-pinyin {
      grid-column: 1;
      grid-row: 2;
      font-size: 0.8rem;
    }
    .entry-hanzi { grid-row: 1; }
    .entry-translation { grid-column: 2; grid-row: 1 / span 2; align-self: center; }
    .entry-actions { grid-column: 3; grid-row: 1 / span 2; }
  }
  @media (max-width: 540px) {
    .featured-card { grid-template-columns: 1fr; text-align: center; }
    .featured-hanzi { grid-row: 1; margin-bottom: var(--spacing-xs); }
    .featured-meta { justify-content: center; }
    .cta-card { padding: var(--spacing-xl); }
    .cta-buttons { flex-direction: column; align-items: stretch; }
  }
</style>
