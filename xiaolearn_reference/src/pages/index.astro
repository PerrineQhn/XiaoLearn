---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;

// URL de l'application (le React/Vite build sera monté sous /app/)
const APP_URL = '/app';
const APP_LOGIN_URL = '/app/login';
---

<BaseLayout title="Accueil">
  <!-- ============================== HERO ============================== -->
  <section class="hero">
    <div class="hero-ornament" aria-hidden="true">学</div>
    <div class="hero-container">
      <span class="hero-eyebrow">Mandarin · A1 → C2</span>
      <h1 class="hero-title">
        Apprends le mandarin.<br />
        <span class="hero-accent">Du A1 jusqu'à courant.</span>
      </h1>
      <p class="hero-lead">
        Passe de total débutant à un niveau courant grâce à un parcours
        structuré, un dictionnaire complet et un professeur disponible 24h/24.
        À ton rythme, en français.
      </p>
      <div class="hero-ctas">
        <a href={APP_URL} class="btn btn-primary btn-lg">Commencer gratuitement</a>
        <a href="#features" class="btn btn-ghost btn-lg">Découvrir la méthode</a>
      </div>
      <p class="hero-foot">Sans carte bancaire · Premières leçons offertes</p>
    </div>
  </section>

  <!-- ============================ STATS BAR ============================ -->
  <section class="stats-bar">
    <div class="container stats-grid">
      <div class="stat-item"><strong>A1 → C2</strong><span>Niveaux CECR</span></div>
      <div class="stat-item"><strong>11 000+</strong><span>Mots indexés (HSK 1 → 7-9)</span></div>
      <div class="stat-item"><strong>500+</strong><span>Points de grammaire</span></div>
      <div class="stat-item"><strong>100%</strong><span>En français</span></div>
    </div>
  </section>

  <!-- ============================ PROBLÈME ============================ -->
  <section class="section problem-section">
    <div class="container">
      <div class="section-header">
        <h2>Apprendre le mandarin ne devrait pas te ruiner.</h2>
        <p>Ni te faire perdre des mois sur des apps qui te récompensent au lieu de t'apprendre.</p>
      </div>

      <div class="problem-grid">
        <article class="problem-card">
          <span class="problem-tag">Écoles de langue</span>
          <p class="problem-price">1 500€<span>/trimestre</span></p>
          <p>Classes surchargées, profs qui ne suivent pas ton rythme, budget qui s'envole.</p>
          <p class="problem-tldr">→ Hors de prix</p>
        </article>

        <article class="problem-card">
          <span class="problem-tag">Prof particulier</span>
          <p class="problem-price">30–50€<span>/heure</span></p>
          <p>Excellent, mais inaccessible au quotidien. 1h/semaine, et tu oublies entre deux.</p>
          <p class="problem-tldr">→ Inaccessible</p>
        </article>

        <article class="problem-card">
          <span class="problem-tag">Apps grand public</span>
          <p class="problem-price">10€<span>/mois</span></p>
          <p>Phrases absurdes, pas de structure CECR, pas de hanzi sérieux. Pour rendre accro, pas bilingue.</p>
          <p class="problem-tldr">→ Illusion de progression</p>
        </article>
      </div>

      <div class="vs-block">
        <div class="vs-card vs-without">
          <h3>Sans XiaoLearn</h3>
          <ul>
            <li><span aria-hidden="true">📑</span> 17 onglets entre Pleco, Yabla, YouTube, MDBG…</li>
            <li><span aria-hidden="true">❓</span> "C'est quel ton sur 妈 ?" pour la 12ᵉ fois</li>
            <li><span aria-hidden="true">😶</span> Tu apprends 谢谢 puis 量子力学</li>
            <li><span aria-hidden="true">📉</span> 80% des mots de la semaine déjà oubliés</li>
          </ul>
        </div>
        <div class="vs-card vs-with">
          <h3>Avec XiaoLearn</h3>
          <ul>
            <li><span aria-hidden="true">🎯</span> Un parcours A1 → C2 en français, structuré</li>
            <li><span aria-hidden="true">🔁</span> Révision espacée, tu n'oublies plus</li>
            <li><span aria-hidden="true">🧠</span> Dictionnaire + grammaire + nuances au même endroit</li>
            <li><span aria-hidden="true">🤖</span> Un prof IA qui répond en français, 24h/24</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ FEATURES ============================ -->
  <section id="features" class="section features-section">
    <div class="container">
      <div class="section-header">
        <span class="badge badge-primary">La méthode</span>
        <h2>Tout ce qu'il te faut.<br /><span class="muted">En un seul endroit.</span></h2>
      </div>

      <div class="features-grid">
        <a href="/dictionnaire" class="feature-card">
          <div class="feature-icon"><span>辞</span></div>
          <h3>Dictionnaire HSK 1 → 7-9</h3>
          <p>Hanzi, pinyin avec tons, traductions, exemples. Accessible sans compte, indexé pour le SEO.</p>
          <span class="feature-cta">Ouvrir le dictionnaire →</span>
        </a>

        <a href="/grammaire" class="feature-card">
          <div class="feature-icon"><span>文</span></div>
          <h3>Grammaire mandarin</h3>
          <p>了, 把, 被, 过, 着, classificateurs, structures — chaque point expliqué clairement, niveau par niveau.</p>
          <span class="feature-cta">Voir la grammaire →</span>
        </a>

        <a href="/nuances" class="feature-card">
          <div class="feature-icon"><span>辨</span></div>
          <h3>Nuances et faux-amis</h3>
          <p>会 / 能 / 可以, 是 / 有, 这 / 那… Comprends les distinctions qui changent tout.</p>
          <span class="feature-cta">Comparer les mots →</span>
        </a>

        <a href="/blog" class="feature-card">
          <div class="feature-icon"><span>文</span></div>
          <h3>Blog &amp; culture</h3>
          <p>Guides, articles, repères culturels, fêtes chinoises. La langue prend tout son sens en contexte.</p>
          <span class="feature-cta">Lire le blog →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================ APP PREVIEW ============================ -->
  <section class="section app-section">
    <div class="container">
      <div class="app-grid">
        <div class="app-copy">
          <span class="badge badge-secondary">L'application web</span>
          <h2>Et quand tu veux pratiquer pour de vrai…</h2>
          <p class="app-lead">
            …l'application XiaoLearn t'attend avec des leçons interactives, un
            système de flashcards à révision espacée, des dialogues, des
            exercices, et un tuteur IA disponible en français 24h/24.
          </p>

          <ul class="app-features">
            <li><strong>Parcours structuré A1 → C2</strong> avec progression suivie</li>
            <li><strong>Flashcards SRS</strong> calibrées sur ton oubli individuel</li>
            <li><strong>Tuteur IA en français</strong> pour grammaire et tons</li>
            <li><strong>Reconnaissance vocale</strong> pour entraîner la prononciation</li>
            <li><strong>Communauté + battles</strong> pour progresser à plusieurs</li>
          </ul>

          <div class="app-ctas">
            <a href={APP_URL} class="btn btn-primary btn-lg">Commencer gratuitement</a>
            <a href={APP_LOGIN_URL} class="btn btn-ghost btn-lg">Se connecter</a>
          </div>
          <p class="app-note">Premières leçons offertes · pas de carte bancaire requise</p>
        </div>

        <div class="app-mockup" aria-hidden="true">
          <div class="mockup-card mockup-card-1">
            <div class="mockup-header">
              <span class="mockup-dot"></span>
              <span class="mockup-dot"></span>
              <span class="mockup-dot"></span>
            </div>
            <div class="mockup-body">
              <div class="mockup-hanzi">你好</div>
              <div class="mockup-pinyin">nǐ hǎo</div>
              <div class="mockup-fr">Bonjour</div>
              <div class="mockup-tags">
                <span class="mockup-tag">A1</span>
                <span class="mockup-tag">À réviser dans 3j</span>
              </div>
            </div>
          </div>

          <div class="mockup-card mockup-card-2">
            <div class="mockup-mini">
              <p class="mockup-q">"Différence 了₁ vs 了₂ ?"</p>
              <p class="mockup-a">了₁ marque l'accomplissement du verbe (我吃了 — j'ai mangé). 了₂ en fin de phrase signale un changement d'état (下雨了 — il s'est mis à pleuvoir)…</p>
            </div>
          </div>

          <div class="mockup-card mockup-card-3">
            <div class="mockup-streak">
              <div class="streak-num">14</div>
              <div class="streak-label">jours de série</div>
            </div>
            <div class="mockup-stats">
              <div class="stat-mini"><strong>342</strong><span>Mots actifs</span></div>
              <div class="stat-mini"><strong>B1</strong><span>Niveau</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ COMMUNAUTÉ ============================ -->
  <section id="community" class="section community-section">
    <div class="container">
      <div class="section-header">
        <span class="badge badge-secondary">Communauté</span>
        <h2>Tu n'apprends pas tout seul.</h2>
        <p>Une communauté d'apprenants francophones du mandarin, motivés et bienveillants.</p>
      </div>

      <div class="community-grid">
        <article class="community-card">
          <h3>Battles de vocabulaire</h3>
          <p>Défie un autre apprenant en 1v1. Le plus rapide à donner la bonne traduction marque les points.</p>
        </article>
        <article class="community-card">
          <h3>Classements</h3>
          <p>Gagne de l'XP à chaque action, monte les paliers, et débloque des récompenses.</p>
        </article>
        <article class="community-card">
          <h3>Board d'entraide</h3>
          <p>Pose tes questions sur les tons, la grammaire, les caractères. Réponds aux autres pour gagner de l'XP.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================ FAQ ============================ -->
  <section class="section faq-section">
    <div class="container container-narrow">
      <div class="section-header">
        <h2>Questions fréquentes</h2>
      </div>

      <details class="faq-item">
        <summary>C'est quoi XiaoLearn ?</summary>
        <p>Une plateforme française pour apprendre le mandarin : un dictionnaire complet HSK 1 → 7-9 accessible sans compte, des points de grammaire et de nuances expliqués clairement, et une application web avec un parcours CECR A1 → C2, des flashcards à révision espacée et un tuteur IA.</p>
      </details>

      <details class="faq-item">
        <summary>Pourquoi le CECR (A1 → C2) plutôt que le HSK ?</summary>
        <p>Le CECR (Cadre Européen Commun de Référence) est le standard utilisé partout en France et en Europe pour mesurer un niveau de langue. Il est plus parlant qu'un niveau HSK pour un francophone. On garde toutefois le HSK comme référence dans le dictionnaire (puisque c'est l'organisation officielle des caractères chinois) et dans les contenus de grammaire.</p>
      </details>

      <details class="faq-item">
        <summary>Pourquoi pas de page "conjugaison" ?</summary>
        <p>Parce que le mandarin <strong>n'a pas de conjugaison</strong> — pas d'accord en temps, en personne ou en nombre. La temporalité passe par des particules (了, 过, 着), des adverbes (已经, 正在), et le contexte. Tu retrouveras tout ça dans la section <a href="/grammaire">Grammaire</a>.</p>
      </details>

      <details class="faq-item">
        <summary>Est-ce que c'est adapté aux vrais débutants ?</summary>
        <p>Oui. Le parcours commence à A1 (zéro caractère, zéro pinyin) et te conduit progressivement jusqu'à C2. L'application introduit les caractères et les tons sans présupposer aucune connaissance préalable.</p>
      </details>

      <details class="faq-item">
        <summary>Je peux essayer gratuitement ?</summary>
        <p>Oui. Le dictionnaire, la grammaire, les nuances et le blog sont entièrement gratuits, sans compte. Pour l'application web (leçons interactives, flashcards, tuteur IA), les premières leçons sont gratuites — pas de carte bancaire requise.</p>
      </details>

      <details class="faq-item">
        <summary>En quoi c'est différent de Pleco ou Duolingo ?</summary>
        <p>Pleco est un excellent dictionnaire mais ne t'enseigne rien. Duolingo te fait traduire des phrases absurdes sans structure CECR ni grammaire claire. XiaoLearn combine un dictionnaire taillé pour francophones, un parcours pédagogique structuré, et un tuteur IA qui répond en français — au même endroit.</p>
      </details>
    </div>
  </section>

  <!-- ============================ PRICING ============================ -->
  <section id="pricing" class="section pricing-section">
    <div class="container">
      <div class="section-header">
        <span class="badge badge-primary">Tarifs</span>
        <h2>Un prix simple. Sans surprise.</h2>
        <p>Commence gratuitement, puis choisis le plan qui te convient.</p>
      </div>

      <!--
        Pricing aligné sur la SubscriptionPage de l'app (xiaolearn_app).
        Source unique de vérité côté features : si tu changes ici, change
        aussi dans /xiaolearn_app/src/pages/SubscriptionPage.tsx pour rester
        cohérent. Inspiration visuelle : seonsaengnim.com/pricing — 2 cards
        seulement, Lifetime en avant avec fond rouge profond et badge
        "Meilleure offre". Le niveau A1 complet est offert sur les 2 plans
        (l'utilisateur doit pouvoir tester en profondeur avant de payer).
      -->
      <div class="pricing-grid pricing-grid--two">
        <article class="pricing-card pricing-monthly">
          <span class="plan-label">Mensuel</span>
          <p class="price">
            <strong>14€</strong>
            <span class="price-unit">/mois</span>
          </p>
          <p class="price-note">Annule quand tu veux</p>
          <a href={APP_URL} class="btn btn-ghost btn-block btn-pricing">Commencer gratuitement</a>
          <ul class="pricing-features">
            <li>Niveau A1 complet — gratuit</li>
            <li>Cours structurés de A1 à C2</li>
            <li>Flashcards avec révision espacée (SRS)</li>
            <li>Prof. Xiao IA disponible 24/7</li>
            <li>Dictionnaire HSK complet + audio</li>
            <li>Communauté d'apprenants</li>
            <li>Sync entre tous tes appareils</li>
          </ul>
        </article>

        <article class="pricing-card pricing-lifetime">
          <span class="pricing-badge">★ Meilleure offre</span>
          <span class="plan-label plan-label--inverse">À vie</span>
          <p class="price price--inverse">
            <strong>99€</strong>
            <span class="price-unit">une seule fois</span>
          </p>
          <p class="price-note price-note--inverse">Accès illimité pour toujours</p>
          <a href={APP_URL} class="btn btn-pricing btn-pricing--filled btn-block">Débloquer l'accès à vie</a>
          <p class="pricing-intro pricing-intro--inverse"><strong>Tout le plan Mensuel, plus :</strong></p>
          <ul class="pricing-features pricing-features--inverse">
            <li>Accès illimité à toutes les fonctionnalités</li>
            <li>Toutes les futures fonctionnalités incluses</li>
            <li>Accès prioritaire aux nouveautés</li>
            <li class="is-exclusive">🎭 Simulateur de Situations (exclusif à vie)</li>
            <li class="is-exclusive">✨ Créer ses propres flashcards (exclusif à vie)</li>
          </ul>
        </article>
      </div>
      <p class="pricing-foot">Les premiers cours sont gratuits. Pas de carte bancaire requise pour commencer.</p>
    </div>
  </section>

  <!-- ============================ FINAL CTA ============================ -->
  <section class="section final-cta-section">
    <div class="container final-cta-inner">
      <h2>Prêt·e à vraiment apprendre le mandarin ?</h2>
      <p>Sans engagement. Sans carte bancaire pour démarrer.</p>
      <div class="final-ctas">
        <a href={APP_URL} class="btn btn-primary btn-lg">Commencer gratuitement</a>
        <a href="/dictionnaire" class="btn btn-ghost btn-lg">Explorer le dictionnaire</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================ HERO ============================ */
  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(4rem, 9vw, 7rem) 0 clamp(3rem, 7vw, 5rem);
    background:
      radial-gradient(circle at 85% 15%, rgba(240, 183, 98, 0.18), transparent 55%),
      radial-gradient(circle at 10% 90%, rgba(216, 72, 62, 0.12), transparent 55%),
      var(--app-bg);
  }

  .hero-ornament {
    position: absolute;
    right: -2vw;
    bottom: -8vw;
    font-family: var(--font-serif);
    font-size: clamp(20rem, 40vw, 36rem);
    color: rgba(216, 72, 62, 0.06);
    line-height: 1;
    user-select: none;
    pointer-events: none;
    z-index: 0;
  }

  .hero-container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
    position: relative;
    z-index: 1;
    text-align: left;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--primary-red);
    background: var(--primary-red-light);
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--radius-full);
    margin-bottom: var(--spacing-xl);
  }

  .hero-title {
    font-size: clamp(2.6rem, 7vw, 5.2rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    font-weight: 700;
    margin-bottom: var(--spacing-lg);
    max-width: 18ch;
  }

  .hero-accent {
    background: linear-gradient(120deg, var(--primary-red), var(--gold-hover));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-lead {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.55;
    color: var(--text-secondary);
    max-width: 56ch;
    margin-bottom: var(--spacing-xl);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .hero-foot {
    font-size: 0.9rem;
    color: var(--text-tertiary);
  }

  /* ============================ STATS BAR ============================ */
  .stats-bar {
    background: var(--bg-primary);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
    padding: var(--spacing-xl) 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-lg);
  }

  .stat-item {
    text-align: center;
  }

  .stat-item strong {
    display: block;
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    color: var(--text-primary);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .stat-item span {
    display: block;
    color: var(--text-tertiary);
    font-size: 0.88rem;
    margin-top: 6px;
  }

  /* ============================ SECTIONS ============================ */
  .section {
    padding: clamp(4rem, 8vw, 6.5rem) 0;
  }

  .container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }

  .container-narrow { max-width: 760px; }

  .section-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto var(--spacing-2xl);
  }

  .section-header h2 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    color: var(--text-primary);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-md);
    font-weight: 700;
  }

  .section-header h2 .muted {
    color: var(--text-tertiary);
    font-weight: 600;
  }

  .section-header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .badge {
    display: inline-block;
    padding: 6px 14px;
    border-radius: var(--radius-full);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-md);
    line-height: 1.4;
  }

  .badge-primary {
    background: var(--primary-red-light);
    color: var(--primary-red);
  }

  .badge-secondary {
    background: var(--jade-green-light);
    color: var(--jade-green);
  }

  /* ============================ PROBLEM ============================ */
  .problem-section {
    background: var(--bg-primary);
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-2xl);
  }

  .problem-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
  }

  .problem-tag {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-md);
  }

  .problem-price {
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .problem-price span {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-tertiary);
    margin-left: 4px;
  }

  .problem-card p {
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: var(--spacing-sm);
  }

  .problem-tldr {
    margin-top: var(--spacing-md) !important;
    color: var(--primary-red) !important;
    font-weight: 700;
  }

  .vs-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
  }

  .vs-card {
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
  }

  .vs-without {
    background: rgba(216, 72, 62, 0.05);
    border: 1px solid rgba(216, 72, 62, 0.18);
  }

  .vs-with {
    background: rgba(47, 157, 138, 0.07);
    border: 1px solid rgba(47, 157, 138, 0.22);
  }

  .vs-card h3 {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-md);
    font-weight: 700;
  }

  .vs-without h3 { color: var(--primary-red); }
  .vs-with h3 { color: var(--jade-green); }

  .vs-card ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .vs-card li {
    display: flex;
    gap: var(--spacing-sm);
    align-items: flex-start;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* ============================ FEATURES ============================ */
  .features-section {
    background: transparent;
  }

  .features-grid {
    display: grid;
