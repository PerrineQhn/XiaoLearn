---
import BaseLayout from '../../layouts/BaseLayout.astro';

const canonicalUrl = 'https://xiaolearn.com/blog';

// Catégories de contenu prévues — affichées en preview pour les visiteurs.
// Quand des articles seront publiés, on remplacera ce hub par un index dynamique.
const categories = [
  {
    name: 'Culture chinoise',
    description: 'Fêtes, philosophie, cinéma, gastronomie — l\'arrière-plan culturel qui donne du sens à la langue.',
    icon: '🏮',
    accent: 'var(--primary-red)',
  },
  {
    name: 'Méthodes d\'apprentissage',
    description: 'Comment apprendre les caractères efficacement, mémoriser les tons, structurer ses révisions.',
    icon: '🎓',
    accent: 'var(--jade-green)',
  },
  {
    name: 'Vie en Chine',
    description: 'Études, voyages, expatriation, immersion linguistique sur le terrain.',
    icon: '🌏',
    accent: 'var(--gold-accent)',
  },
  {
    name: 'Linguistique',
    description: 'Étymologie des caractères, dialectes, évolution du mandarin moderne.',
    icon: '📜',
    accent: '#6c4cb8',
  },
];
---

<BaseLayout
  title="Blog"
  description="Articles, méthodes et culture chinoise — le blog XiaoLearn arrive bientôt."
  canonical={canonicalUrl}
>
  <section class="blog-hero">
    <div class="container">
      <span class="hero-eyebrow">📝 Blog</span>
      <h1>Articles & culture chinoise</h1>
      <p class="hero-lead">
        Le blog XiaoLearn ouvre bientôt. Méthodes d'apprentissage,
        culture chinoise, vie en Chine, linguistique — des articles
        écrits par notre équipe et des invités.
      </p>
      <span class="blog-soon-badge">🛠️ En préparation — premiers articles prévus pour juillet 2026</span>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Les catégories prévues</h2>
        <p>Voici les thèmes que tu retrouveras dès le lancement du blog.</p>
      </div>
      <div class="blog-grid">
        {categories.map(cat => (
          <article class="blog-cat-card" style={`--card-accent: ${cat.accent}`}>
            <div class="card-icon" aria-hidden="true">{cat.icon}</div>
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--notify">
    <div class="container">
      <div class="notify-card">
        <h2>Préviens-moi à l'ouverture du blog</h2>
        <p>
          On t'enverra un mail à la publication du premier article.
          Pas de spam, pas de promo — uniquement un avis quand le blog
          est en ligne.
        </p>
        <form
          class="notify-form"
          action="https://formspree.io/f/mvgaknqr"
          method="post"
        >
          <label class="visually-hidden" for="blog-email">Adresse email</label>
          <input
            id="blog-email"
            type="email"
            name="email"
            placeholder="ton@email.com"
            required
            class="notify-input"
          />
          <input type="hidden" name="_subject" value="XiaoLearn — Notif blog ouverture" />
          <input type="hidden" name="source" value="blog-coming-soon" />
          <button type="submit" class="btn btn-primary">Me prévenir</button>
        </form>
        <p class="notify-foot">
          Tu peux aussi <a href="https://app.xiaolearn.com">essayer l'app</a>
          en attendant.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    padding: clamp(2.5rem, 6vw, 4.5rem) 0 clamp(1.5rem, 3vw, 2.5rem);
    background:
      radial-gradient(circle at 85% 15%, rgba(240, 183, 98, 0.15), transparent 55%),
      radial-gradient(circle at 10% 90%, rgba(216, 72, 62, 0.1), transparent 55%),
      var(--app-bg);
    text-align: center;
  }
  .hero-eyebrow {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--primary-red);
    background: var(--primary-red-light);
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--radius-full);
    margin-bottom: var(--spacing-md);
  }
  .blog-hero h1 {
    margin: 0 auto var(--spacing-md);
    max-width: 18ch;
  }
  .hero-lead {
    max-width: 56ch;
    margin: 0 auto var(--spacing-lg);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .blog-soon-badge {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-lg);
    background: var(--bg-primary);
    border: 1px dashed var(--border-medium);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-xl);
  }
  .blog-cat-card {
    padding: var(--spacing-2xl);
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-left: 4px solid var(--card-accent, var(--primary-red));
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  .blog-cat-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .card-icon {
    font-size: 1.75rem;
    line-height: 1;
    margin-bottom: var(--spacing-sm);
  }
  .blog-cat-card h3 {
    margin: 0 0 var(--spacing-sm);
    font-size: 1.2rem;
    color: var(--text-primary);
  }
  .blog-cat-card p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .section--notify { padding-top: 0; }
  .notify-card {
    background: linear-gradient(135deg, var(--primary-red-light), #fbe9b8);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: var(--spacing-2xl);
    text-align: center;
  }
  .notify-card h2 { margin: 0 0 var(--spacing-sm); }
  .notify-card p {
    max-width: 56ch;
    margin: 0 auto var(--spacing-lg);
    color: var(--text-secondary);
  }
  .notify-form {
    display: flex;
    gap: var(--spacing-sm);
    max-width: 440px;
    margin: 0 auto var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
  }
  .notify-input {
    flex: 1;
    min-width: 240px;
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--border-medium);
    border-radius: var(--radius-md);
    font: inherit;
    background: var(--bg-primary);
    color: var(--text-primary);
  }
  .notify-input:focus {
    outline: none;
    border-color: var(--primary-red);
    box-shadow: 0 0 0 3px var(--primary-red-light);
  }
  .notify-foot {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    margin: 0;
  }
  .notify-foot a {
    color: var(--primary-red);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 820px) {
    .blog-grid { grid-template-columns: 1fr; gap: var(--spacing-md); }
    .blog-cat-card { padding: var(--spacing-xl); }
    .notify-card { padding: var(--spacing-xl); }
  }
  @media (max-width: 540px) {
    .notify-form { flex-direction: column; }
    .notify-input { width: 100%; min-width: 0; }
  }
</style>
