---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import DictionarySearch from '../../../components/react/DictionarySearch';
import { HSK_LEVELS } from '../../../types/hsk';
import { getHorsHskMeta } from '../../../utils/horsHskCatalog';
import { getHskMeta } from '../../../utils/hskCatalog';

export const prerender = true;

const horsHskMeta = await getHorsHskMeta(Astro.url);
const hskMeta = await getHskMeta(Astro.url);

const stats = {
  total: Object.values(hskMeta.levels).reduce((sum, count) => sum + count, 0),
  hsk1: hskMeta.levels.hsk1,
  hsk2: hskMeta.levels.hsk2,
  hsk3: hskMeta.levels.hsk3,
  hsk4: hskMeta.levels.hsk4,
  hsk5: hskMeta.levels.hsk5,
  hsk6: hskMeta.levels.hsk6,
  hsk7: hskMeta.levels.hsk7,
  'hors-hsk': horsHskMeta.totalEntries,
};
---

<BaseLayout
  title="Dictionary"
  description="Chinese-English dictionary for HSK 1 to HSK 7-9 with pinyin, tags and examples."
  lang="en"
>
  <section class="page-header">
    <div class="container">
      <Breadcrumb items={[{ label: 'Dictionary' }]} locale="en" />
      <h1>Chinese-English <span class="text-gradient">dictionary</span></h1>
      <p>
        More than {stats.total.toLocaleString()} words from HSK 1 to HSK 7-9.
      </p>
      <p>
        Out-of-HSK terms are currently available on the French pages.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="level-overview">
        {HSK_LEVELS.map(level => (
          level.slug === 'hors-hsk' ? (
            <a
              href="/dictionnaire/hors-hsk"
              class="level-card"
              style={`--level-color: ${level.color}; --level-bg: ${level.bgColor}`}
            >
              <span class="level-count">
                {stats[level.slug as keyof typeof stats]?.toLocaleString()}
              </span>
              <span class="level-name">Out of HSK (FR)</span>
            </a>
          ) : (
            <a
              href={`/en/dictionnaire?level=${level.slug}`}
              class="level-card"
              style={`--level-color: ${level.color}; --level-bg: ${level.bgColor}`}
            >
              <span class="level-count">
                {stats[level.slug as keyof typeof stats]?.toLocaleString()}
              </span>
              <span class="level-name">{level.name}</span>
            </a>
          )
        ))}
      </div>

      <div class="search-section">
        <DictionarySearch
          client:load
          entriesUrl="/data/hsk/all.json"
          locale="en"
          resultBasePath="/en/dictionnaire"
        />
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--bg-accent), var(--bg-secondary));
    padding: var(--spacing-2xl) 0;
    border-bottom: 1px solid var(--border-light);
  }

  .page-header h1 {
    margin-bottom: var(--spacing-sm);
  }

  .page-header p {
    max-width: 640px;
  }

  .level-overview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-2xl);
  }

  .level-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--spacing-lg);
    background: var(--level-bg);
    border-radius: var(--radius-lg);
    border: 2px solid transparent;
    transition: all var(--transition-base);
    text-align: center;
  }

  .level-card:hover {
    border-color: var(--level-color);
    transform: translateY(-2px);
  }

  .level-count {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--level-color);
  }

  .level-name {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .search-section {
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    border: 1px solid var(--border-light);
  }

  @media (max-width: 768px) {
    .level-overview {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<style is:global>
  .dictionary-search {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .search-controls {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .search-input-wrapper {
    position: relative;
  }

  .search-input-wrapper .search-input {
    width: 100%;
    padding-right: 3rem;
  }

  .search-clear {
    position: absolute;
    right: var(--spacing-md);
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--text-tertiary);
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }

  .search-clear:hover {
    color: var(--text-primary);
  }

  .level-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .level-btn {
    padding: var(--spacing-sm) var(--spacing-md);
    border: 2px solid var(--border-light);
    border-radius: var(--radius-md);
    background: var(--bg-primary);
    color: var(--text-secondary);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .level-btn:hover {
    border-color: var(--primary-red);
    color: var(--primary-red);
  }

  .level-btn.active {
    background: var(--primary-red);
    border-color: var(--primary-red);
    color: white;
  }

  .level-btn-hsk1.active {
    background: #2E7D32;
    border-color: #2E7D32;
  }

  .level-btn-hsk2.active {
    background: #1565C0;
    border-color: #1565C0;
  }

  .level-btn-hsk3.active {
    background: #E65100;
    border-color: #E65100;
  }

  .level-btn-hsk4.active {
    background: #C2185B;
    border-color: #C2185B;
  }

  .level-btn-hsk5.active {
    background: #6A1B9A;
    border-color: #6A1B9A;
  }

  .level-btn-hsk6.active {
    background: #006064;
    border-color: #006064;
  }

  .level-btn-hsk7.active {
    background: #BF360C;
    border-color: #BF360C;
  }

  .level-btn-hors-hsk.active {
    background: #546E7A;
    border-color: #546E7A;
  }

  .search-results-info {
    font-size: 0.9rem;
    color: var(--text-tertiary);
  }

  .results-limited {
    font-style: italic;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--spacing-md);
  }

  .result-card {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-md);
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    transition: all var(--transition-base);
  }

  .result-card:hover {
    border-color: var(--primary-red-light);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .result-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--spacing-xs);
  }

  .result-hanzi {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    line-height: 1;
    color: var(--text-primary);
  }

  .result-level {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  .result-pinyin {
    font-style: italic;
    font-size: 0.9rem;
    color: var(--jade-green);
    margin-bottom: var(--spacing-xs);
  }

  .result-translation {
    font-size: 0.85rem;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .no-results {
    text-align: center;
    padding: var(--spacing-2xl);
    color: var(--text-tertiary);
  }

  .no-results-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: var(--spacing-md);
  }

  .no-results-hint {
    font-size: 0.9rem;
    margin-top: var(--spacing-sm);
  }
</style>
