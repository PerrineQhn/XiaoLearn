---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const canonicalUrl = 'https://xiaolearn.com/en/blog';

const categories = [
  {
    name: 'Chinese culture',
    description: 'Festivals, philosophy, cinema, food — the cultural background that gives the language meaning.',
    icon: '🏮',
    accent: 'var(--primary-red)',
  },
  {
    name: 'Learning methods',
    description: 'How to learn characters efficiently, memorize tones, structure your reviews.',
    icon: '🎓',
    accent: 'var(--jade-green)',
  },
  {
    name: 'Life in China',
    description: 'Studies, travel, expat life, language immersion on the ground.',
    icon: '🌏',
    accent: 'var(--gold-accent)',
  },
  {
    name: 'Linguistics',
    description: 'Character etymology, dialects, evolution of modern Mandarin.',
    icon: '📜',
    accent: '#6c4cb8',
  },
];
---

<BaseLayout
  title="Blog"
  description="Articles, methods and Chinese culture — the XiaoLearn blog is coming soon."
  canonical={canonicalUrl}
  lang="en"
>
  <section class="blog-hero">
    <div class="container">
      <span class="hero-eyebrow">📝 Blog</span>
      <h1>Articles & Chinese culture</h1>
      <p class="hero-lead">
        The XiaoLearn blog is coming soon. Learning methods,
        Chinese culture, life in China, linguistics — articles
        written by our team and guest authors.
      </p>
      <span class="blog-soon-badge">🛠️ Coming soon — first articles expected July 2026</span>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Categories on the way</h2>
        <p>Here are the themes you'll find when the blog launches.</p>
      </div>
      <div class="blog-grid">
        {categories.map(cat => (
          <article class="blog-cat-card" style={`--card-accent: ${cat.accent}`}>
            <div class="card-icon" aria-hidden="true">{cat.icon}</div>
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--notify">
    <div class="container">
      <div class="notify-card">
        <h2>Notify me when the blog opens</h2>
        <p>
          We'll email you when the first article is published.
          No spam, no promo — just a heads-up when the blog is live.
        </p>
        <form
          class="notify-form"
          action="https://formspree.io/f/mvgaknqr"
          method="post"
        >
          <label class="visually-hidden" for="blog-email-en">Email address</label>
          <input
            id="blog-email-en"
            type="email"
            name="email"
            placeholder="you@email.com"
            required
            class="notify-input"
          />
          <input type="hidden" name="_subject" value="XiaoLearn — Blog open notification" />
          <input type="hidden" name="source" value="blog-coming-soon-en" />
          <button type="submit" class="btn btn-primary">Notify me</button>
        </form>
        <p class="notify-foot">
          You can also <a href="https://app.xiaolearn.com?lang=en">try the app</a>
          in the meantime.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    padding: clamp(2.5rem, 6vw, 4.5rem) 0 clamp(1.5rem, 3vw, 2.5rem);
    background:
      radial-gradient(circle at 85% 15%, rgba(240, 183, 98, 0.15), transparent 55%),
      radial-gradient(circle at 10% 90%, rgba(216, 72, 62, 0.1), transparent 55%),
      var(--app-bg);
    text-align: center;
  }
  .hero-eyebrow {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--primary-red);
    background: var(--primary-red-light);
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--radius-full);
    margin-bottom: var(--spacing-md);
  }
  .blog-hero h1 { margin: 0 auto var(--spacing-md); max-width: 18ch; }
  .hero-lead {
    max-width: 56ch;
    margin: 0 auto var(--spacing-lg);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .blog-soon-badge {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-lg);
    background: var(--bg-primary);
    border: 1px dashed var(--border-medium);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 500;
  }
  .blog-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--spacing-xl); }
  .blog-cat-card {
    padding: var(--spacing-2xl);
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-left: 4px solid var(--card-accent, var(--primary-red));
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  .blog-cat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .card-icon { font-size: 1.75rem; line-height: 1; margin-bottom: var(--spacing-sm); }
  .blog-cat-card h3 { margin: 0 0 var(--spacing-sm); font-size: 1.2rem; color: var(--text-primary); }
  .blog-cat-card p { margin: 0; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.55; }

  .section--notify { padding-top: 0; }
  .notify-card {
    /* Mono-rouge : aligné palette logo (plus d'or/miel). */
    background: linear-gradient(135deg, var(--primary-red-light), #fef5f3);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: var(--spacing-2xl);
    text-align: center;
  }
  .notify-card h2 { margin: 0 0 var(--spacing-sm); }
  .notify-card p { max-width: 56ch; margin: 0 auto var(--spacing-lg); color: var(--text-secondary); }
  .notify-form {
    display: flex;
    gap: var(--spacing-sm);
    max-width: 440px;
    margin: 0 auto var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
  }
  .notify-input {
    flex: 1;
    min-width: 240px;
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--border-medium);
    border-radius: var(--radius-md);
    font: inherit;
    background: var(--bg-primary);
    color: var(--text-primary);
  }
  .notify-input:focus {
    outline: none;
    border-color: var(--primary-red);
    box-shadow: 0 0 0 3px var(--primary-red-light);
  }
  .notify-foot { font-size: 0.85rem; color: var(--text-tertiary); margin: 0; }
  .notify-foot a { color: var(--primary-red); text-decoration: underline; text-underline-offset: 2px; }

  @media (max-width: 820px) {
    .blog-grid { grid-template-columns: 1fr; gap: var(--spacing-md); }
    .blog-cat-card { padding: var(--spacing-xl); }
    .notify-card { padding: var(--spacing-xl); }
  }
  @media (max-width: 540px) {
    .notify-form { flex-direction: column; }
    .notify-input { width: 100%; min-width: 0; }
  }
</style>
