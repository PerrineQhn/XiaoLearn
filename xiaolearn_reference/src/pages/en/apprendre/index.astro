---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const canonicalUrl = 'https://xiaolearn.com/en/apprendre';
const sections = [
  {
    title: 'Dictionary',
    description: '7 HSK levels + beyond-HSK, 5 000+ entries with pinyin, translation, audio examples.',
    href: '/en/dictionnaire',
    accent: 'var(--primary-red)',
    icon: '📖',
    cta: 'Explore the dictionary',
  },
  {
    title: 'Grammar',
    description: 'Structured cards by level and topic. Targeted exercises, audio examples, detailed nuances.',
    href: '/en/grammaire',
    accent: 'var(--jade-green)',
    icon: '📐',
    cta: 'Browse grammar',
  },
  {
    title: 'Nuances',
    description: 'Fine distinctions between near-synonyms or close turns of phrase. Essential to sound native.',
    href: '/en/nuances',
    accent: 'var(--gold-accent)',
    icon: '🔍',
    cta: 'Discover nuances',
  },
  {
    title: 'Resources',
    description: 'Hand-picked books, podcasts, films and apps to support your journey.',
    href: '/ressources',
    accent: '#6c4cb8',
    icon: '📚',
    cta: 'See resources',
  },
];
---

<BaseLayout
  title="Learn Mandarin"
  description="Everything you need to learn Mandarin Chinese: HSK dictionary, grammar, nuances and curated resources."
  canonical={canonicalUrl}
  lang="en"
>
  <section class="learn-hero">
    <div class="container">
      <span class="hero-eyebrow">Learn · From A1 to fluent</span>
      <h1>Learn Mandarin</h1>
      <p class="hero-lead">
        Every XiaoLearn resource in one place. Start with the dictionary
        for vocabulary, or dive into grammar and nuances to sound like
        a native speaker.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="learn-grid">
        {sections.map(s => (
          <a href={s.href} class="learn-card" style={`--card-accent: ${s.accent}`}>
            <div class="card-icon" aria-hidden="true">{s.icon}</div>
            <h2>{s.title}</h2>
            <p>{s.description}</p>
            <span class="card-cta">
              {s.cta} <span class="arrow">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--app-cta">
    <div class="container">
      <div class="app-cta-card">
        <h2>Go further with the XiaoLearn app</h2>
        <p>
          Interactive lessons, SRS flashcards, conversation simulator
          with Prof. Xiao, vocabulary battles — the full learning experience.
        </p>
        <div class="app-cta-buttons">
          <a href="https://app.xiaolearn.com?lang=en" class="btn btn-primary">Start free</a>
          <a href="https://app.xiaolearn.com/login?lang=en" class="btn btn-ghost">Sign in</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .learn-hero {
    padding: clamp(2.5rem, 6vw, 4.5rem) 0 clamp(1.5rem, 3vw, 2.5rem);
    background:
      radial-gradient(circle at 85% 15%, rgba(240, 183, 98, 0.15), transparent 55%),
      radial-gradient(circle at 10% 90%, rgba(216, 72, 62, 0.1), transparent 55%),
      var(--app-bg);
    text-align: center;
  }
  .hero-eyebrow {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--primary-red);
    background: var(--primary-red-light);
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--radius-full);
    margin-bottom: var(--spacing-md);
  }
  .learn-hero h1 {
    margin: 0 auto var(--spacing-md);
    max-width: 18ch;
  }
  .hero-lead {
    max-width: 56ch;
    margin: 0 auto;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .learn-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-xl);
  }
  .learn-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    padding: var(--spacing-2xl);
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-top: 4px solid var(--card-accent, var(--primary-red));
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    color: inherit;
    text-decoration: none;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  .learn-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .card-icon { font-size: 2rem; line-height: 1; margin-bottom: var(--spacing-xs); }
  .learn-card h2 { margin: 0; font-size: 1.4rem; color: var(--text-primary); }
  .learn-card p { margin: 0 0 var(--spacing-md); color: var(--text-secondary); font-size: 0.95rem; line-height: 1.55; }
  .card-cta {
    margin-top: auto;
    color: var(--card-accent, var(--primary-red));
    font-weight: 600;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
  }
  .card-cta .arrow { transition: transform var(--transition-base); }
  .learn-card:hover .card-cta .arrow { transform: translateX(4px); }

  .section--app-cta { padding-top: 0; }
  .app-cta-card {
    background: linear-gradient(135deg, var(--primary-red-light), #fbe9b8);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: var(--spacing-2xl);
    text-align: center;
  }
  .app-cta-card h2 { margin: 0 0 var(--spacing-sm); }
  .app-cta-card p { max-width: 60ch; margin: 0 auto var(--spacing-lg); color: var(--text-secondary); }
  .app-cta-buttons { display: inline-flex; gap: var(--spacing-md); flex-wrap: wrap; justify-content: center; }

  @media (max-width: 820px) {
    .learn-grid { grid-template-columns: 1fr; gap: var(--spacing-md); }
    .learn-card { padding: var(--spacing-xl); }
    .app-cta-card { padding: var(--spacing-xl); }
  }
  @media (max-width: 540px) {
    .app-cta-buttons { flex-direction: column; align-items: stretch; }
  }
</style>
