---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  getLocaleFromPathname,
  getOgLocale,
  getSiteName,
  isLocalePathAvailable,
  localizePath,
  stripLocalePrefix,
  type Locale,
} from '../utils/locale';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  robots?: string;
  lang?: Locale;
}

const {
  title,
  description,
  canonical,
  robots = 'index,follow',
  lang,
} = Astro.props;

const locale = lang || getLocaleFromPathname(Astro.url.pathname);
const defaultDescription = locale === 'en'
  ? 'Learn Mandarin Chinese with dictionary entries, grammar notes, word nuances and cultural references.'
  : 'Apprenez le chinois mandarin : dictionnaire, grammaire et nuances expliquees en francais pour les francophones.';
const pageDescription = description || defaultDescription;
const siteName = getSiteName(locale);
const homeSubtitle = locale === 'en' ? 'Learn Mandarin' : 'Apprendre le mandarin';
const fullTitle = (title === 'Accueil' || title === 'Home')
  ? `${siteName} - ${homeSubtitle}`
  : `${title} | ${siteName}`;
const siteOrigin = Astro.site?.toString() || 'https://xiaolearn.com';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteOrigin).toString();
const basePath = stripLocalePrefix(Astro.url.pathname);
const alternateFr = new URL(localizePath(basePath, 'fr'), siteOrigin).toString();
const alternateEn = isLocalePathAvailable(basePath, 'en')
  ? new URL(localizePath(basePath, 'en'), siteOrigin).toString()
  : null;
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={pageDescription} />
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hrefLang="fr" href={alternateFr} />
  {alternateEn && <link rel="alternate" hrefLang="en" href={alternateEn} />}
  <link rel="alternate" hrefLang="x-default" href={alternateFr} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content={getOgLocale(locale)} />
  <meta property="og:site_name" content={siteName} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={pageDescription} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/logos/logo_onglet.png" />

  <title>{fullTitle}</title>
</head>
<body>
  <Header locale={locale} />

  <main>
    <slot />
  </main>

  <Footer locale={locale} />
</body>
</html>

<style>
  main {
    min-height: calc(100vh - var(--header-height) - 300px);
  }
</style>
