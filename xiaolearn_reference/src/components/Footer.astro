---
import { getFooterSections, getLegalLinks } from '../data/navigation';
import { localizePath, getLocaleSwitchPath, type Locale } from '../utils/locale';

interface Props {
  locale?: Locale;
}

const { locale = 'fr' } = Astro.props;
const footerSections = getFooterSections(locale);
const legalLinks = getLegalLinks(locale);

const currentYear = new Date().getFullYear();
const homeHref = localizePath('/', locale);
const tagline = locale === 'en'
  ? 'The reference site to learn Mandarin Chinese. Dictionary, grammar cards, lexical nuances and cultural context.'
  : 'Le site de reference pour apprendre le chinois mandarin en francais. Dictionnaire complet, fiches de grammaire, nuances lexicales et reperes culturels.';
const freeBadge = locale === 'en' ? 'Free content' : 'Contenu gratuit';
const hskBadge = locale === 'en' ? 'Official HSK 3.0' : 'HSK 3.0 officiel';
const rights = locale === 'en' ? 'All rights reserved.' : 'Tous droits reserves.';

// Sélecteur de langue : URLs vers la même page dans l'autre locale
const frHref = Astro.url ? getLocaleSwitchPath(Astro.url.pathname, 'fr') : '/';
const enHref = Astro.url ? getLocaleSwitchPath(Astro.url.pathname, 'en') : '/en';
const currentLangLabel = locale === 'en' ? 'English' : 'Français';
const languageSwitchLabel = locale === 'en' ? 'Choose interface language' : "Choisir la langue de l'interface";
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-brand">
      <a href={homeHref} class="footer-logo">
        <img src="/logos/logo_asian-red.png" alt="XiaoLearn" />
      </a>
      <p class="footer-tagline">
        {tagline}
      </p>
      <div class="footer-badges">
        <span class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
          {freeBadge}
        </span>
        <span class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <path d="M9 12l2 2 4-4"/>
          </svg>
          {hskBadge}
        </span>
      </div>
    </div>

    <div class="footer-links">
      {footerSections.map(section => (
        <div class="footer-column">
          <h4>{section.title}</h4>
          <ul>
            {section.links.map(link => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener' : undefined}
                >
                  {link.label}
                  {link.external && <span class="external-icon">↗</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-container">
      <p>&copy; {currentYear} XiaoLearn. {rights}</p>

      <div
        class="footer-lang-switch"
        role="group"
        aria-label={languageSwitchLabel}
      >
        <button
          type="button"
          class="footer-lang-toggle"
          aria-haspopup="true"
          aria-expanded="false"
        >
          <svg class="footer-lang-globe" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          <span class="footer-lang-current">{currentLangLabel}</span>
          <span class="footer-lang-arrow" aria-hidden="true">▾</span>
        </button>
        <div class="footer-lang-menu" role="menu">
          <a
            href={frHref}
            class={`footer-lang-option ${locale === 'fr' ? 'is-active' : ''}`}
            role="menuitem"
          >
            Français (FR)
          </a>
          <a
            href={enHref}
            class={`footer-lang-option ${locale === 'en' ? 'is-active' : ''}`}
            role="menuitem"
          >
            English (EN)
          </a>
        </div>
      </div>

      <div class="footer-legal">
        {legalLinks.map(link => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-primary);
    border-top: 1px solid var(--border-light);
    margin-top: auto;
  }

  .footer-container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--spacing-3xl) var(--spacing-lg);
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: var(--spacing-2xl);
  }

  .footer-brand {
    max-width: 320px;
  }

  .footer-logo img {
    height: 45px;
    width: auto;
    margin-bottom: var(--spacing-md);
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
    line-height: 1.6;
  }

  .footer-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-xs) var(--spacing-sm);
    background: var(--jade-green-light);
    color: var(--jade-green);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .footer-column h4 {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-column ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .footer-column a {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: 0.9rem;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }

  .footer-column a:hover {
    color: var(--primary-red);
  }

  .external-icon {
    font-size: 0.8rem;
    opacity: 0.7;
  }

  .footer-links {
    display: contents;
  }

  .footer-bottom {
    border-top: 1px solid var(--border-light);
  }

  .footer-bottom-container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--spacing-lg);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom p {
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .footer-legal {
    display: flex;
    gap: var(--spacing-lg);
  }

  .footer-legal a {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    transition: color var(--transition-fast);
  }

  .footer-legal a:hover {
    color: var(--primary-red);
  }

  /* ------------------------------------------------------------------
   * Sélecteur de langue dans le footer
   * ------------------------------------------------------------------ */
  .footer-lang-switch {
    position: relative;
  }
  .footer-lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: 0.4rem 0.8rem;
    background: transparent;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
  }
  .footer-lang-toggle:hover,
  .footer-lang-toggle:focus-visible {
    border-color: var(--primary-red);
    color: var(--text-primary);
    background: var(--bg-secondary);
    outline: none;
  }
  .footer-lang-globe {
    flex-shrink: 0;
    opacity: 0.7;
  }
  .footer-lang-current {
    font-weight: 500;
  }
  .footer-lang-arrow {
    font-size: 0.7rem;
    opacity: 0.6;
    transition: transform var(--transition-fast);
  }
  .footer-lang-switch:hover .footer-lang-arrow,
  .footer-lang-switch:focus-within .footer-lang-arrow {
    transform: rotate(180deg);
  }

  .footer-lang-menu {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    min-width: 180px;
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-fast), transform var(--transition-fast), visibility var(--transition-fast);
    z-index: 50;
  }
  .footer-lang-switch:hover .footer-lang-menu,
  .footer-lang-switch:focus-within .footer-lang-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .footer-lang-option {
    padding: 8px 12px;
    font-size: 0.9rem;
    color: var(--text-secondary);
    border-radius: var(--radius-sm);
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .footer-lang-option:hover {
    background: var(--primary-red-light);
    color: var(--primary-red);
  }
  .footer-lang-option.is-active {
    color: var(--text-primary);
    background: var(--bg-accent);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .footer-container {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .footer-container {
      grid-template-columns: 1fr;
    }

    .footer-bottom-container {
      flex-direction: column;
      gap: var(--spacing-sm);
      text-align: center;
    }
  }
</style>
