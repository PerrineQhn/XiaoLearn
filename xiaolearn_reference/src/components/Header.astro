---
import { externalLinks, getMainNav, getCtaLinks } from '../data/navigation';
import { localizePath, type Locale } from '../utils/locale';

interface Props {
  locale?: Locale;
}

const { locale = 'fr' } = Astro.props;
const mainNav = getMainNav(locale);
const ctaLinks = getCtaLinks(locale);

// Le sélecteur de langue a été déplacé vers le footer. Les variables qui
// le concernaient (frHref, enHref, languageSwitchLabel) ont été retirées.

const currentQuery = Astro.url.searchParams.get('q') || '';
const homeHref = localizePath('/', locale);
const searchAction = locale === 'en' ? '/en/dictionnaire' : '/recherche';
const searchLabel = locale === 'en' ? 'Search the website' : 'Rechercher sur le site';
const mobileSearchPlaceholder = locale === 'en' ? 'Search...' : 'Rechercher...';
const mobileSearchButton = locale === 'en' ? 'Search' : 'Rechercher';
---

<header class="header">
  <div class="header-container">
    <a href={homeHref} class="logo">
      <img src="/logos/logo_long.png" alt="XiaoLearn" class="logo-img" />
    </a>

    <nav class="nav">
      {mainNav.map(item => (
        item.children && item.children.length > 0 ? (
          <div class="nav-dropdown">
            <a
              href={item.href}
              class="nav-link nav-link--dropdown"
              aria-haspopup="true"
            >
              {item.label}
              <span class="nav-dropdown-arrow" aria-hidden="true">▾</span>
            </a>
            <div class="nav-submenu" role="menu">
              {item.children.map(child => (
                <a
                  href={child.href}
                  class="nav-submenu-link"
                  target={child.external ? '_blank' : undefined}
                  rel={child.external ? 'noopener' : undefined}
                  role="menuitem"
                >
                  {child.label}
                  {child.external && <span class="nav-external">↗</span>}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="nav-link"
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener' : undefined}
          >
            {item.label}
            {item.external && <span class="nav-external">↗</span>}
          </a>
        )
      ))}
    </nav>

    <div class="header-actions">
      {ctaLinks.map(cta => (
        <a
          href={cta.href}
          class={`btn btn-sm ${cta.variant === 'primary' ? 'btn-primary' : 'btn-ghost'}`}
        >
          {cta.label}
        </a>
      ))}
      {externalLinks.map(link => (
        <a
          href={link.href}
          class="btn btn-sm btn-secondary"
          target="_blank"
          rel="noopener"
        >
          {link.label}
        </a>
      ))}
    </div>

    <button class="mobile-menu-btn" aria-label="Menu" id="mobile-menu-btn">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu">
    <form class="mobile-search" action={searchAction} method="get" role="search">
      <label for="mobile-search-input" class="visually-hidden">{searchLabel}</label>
      <input
        id="mobile-search-input"
        class="mobile-search-input"
        type="search"
        name="q"
        value={currentQuery}
        placeholder={mobileSearchPlaceholder}
      />
      <button type="submit" class="mobile-search-btn">{mobileSearchButton}</button>
    </form>

    <nav class="mobile-nav">
      {mainNav.map(item => (
        item.children && item.children.length > 0 ? (
          <>
            <a
              href={item.href}
              class="mobile-nav-link mobile-nav-link--group"
            >
              {item.label}
            </a>
            {item.children.map(child => (
              <a
                href={child.href}
                class="mobile-nav-link mobile-nav-link--child"
                target={child.external ? '_blank' : undefined}
                rel={child.external ? 'noopener' : undefined}
              >
                <span class="mobile-nav-child-bullet" aria-hidden="true">›</span>
                {child.label}
                {child.external && <span class="external-icon">↗</span>}
              </a>
            ))}
          </>
        ) : (
          <a
            href={item.href}
            class="mobile-nav-link"
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener' : undefined}
          >
            {item.label}
            {item.external && <span class="external-icon">↗</span>}
          </a>
        )
      ))}
      <hr />
      {ctaLinks.map(cta => (
        <a
          href={cta.href}
          class={`mobile-nav-link mobile-cta ${cta.variant === 'primary' ? 'mobile-cta-primary' : ''}`}
        >
          {cta.label}
        </a>
      ))}
      {externalLinks.length > 0 && (
        <>
          <hr />
          {externalLinks.map(link => (
            <a
              href={link.href}
              class="mobile-nav-link external"
              target="_blank"
              rel="noopener"
            >
              {link.label}
              <span class="external-icon">↗</span>
            </a>
          ))}
        </>
      )}
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
    menuBtn.classList.toggle('open');
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-primary);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-light);
    height: var(--header-height);
  }

  .header-container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
    height: 100%;
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-shrink: 0;
  }

  .logo-img {
    height: 56px;
    width: auto;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    justify-content: center;
    min-width: 0;
  }

  .nav-link {
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-secondary);
    padding: 8px 14px;
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--primary-red);
    background: var(--primary-red-light);
  }

  /* Dropdown desktop ---------------------------------------------------- */
  .nav-dropdown {
    position: relative;
  }
  .nav-link--dropdown {
    cursor: pointer;
  }
  .nav-dropdown-arrow {
    font-size: 0.7rem;
    opacity: 0.6;
    margin-left: 2px;
    transition: transform var(--transition-fast);
  }
  .nav-dropdown:hover .nav-dropdown-arrow,
  .nav-dropdown:focus-within .nav-dropdown-arrow {
    transform: rotate(180deg);
  }
  .nav-submenu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 200px;
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity var(--transition-fast), transform var(--transition-fast), visibility var(--transition-fast);
    z-index: 120;
  }
  .nav-dropdown:hover .nav-submenu,
  .nav-dropdown:focus-within .nav-submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav-submenu-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    border-radius: var(--radius-sm);
    transition: background var(--transition-fast), color var(--transition-fast);
    white-space: nowrap;
  }
  .nav-submenu-link:hover {
    background: var(--primary-red-light);
    color: var(--primary-red);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-shrink: 0;
  }

  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
  }

  .lang-link {
    color: var(--text-tertiary);
    font-weight: 600;
    font-size: 0.8rem;
    line-height: 1;
    transition: color var(--transition-fast);
  }

  .lang-link:hover {
    color: var(--primary-red);
  }

  .lang-link.active {
    color: var(--text-primary);
  }

  .lang-separator {
    color: var(--text-tertiary);
    font-size: 0.72rem;
    line-height: 1;
  }

  .header-search {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--spacing-xs);
    align-items: center;
    justify-self: end;
    width: min(100%, 310px);
  }

  .header-search-input {
    height: 40px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font: inherit;
    padding: 0 var(--spacing-md);
    min-width: 0;
  }

  .header-search-input:focus {
    outline: none;
    border-color: var(--primary-red);
    box-shadow: 0 0 0 3px var(--primary-red-light);
  }

  .header-search-input::placeholder {
    color: var(--text-tertiary);
  }

  .header-search-btn {
    height: 40px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    background: var(--bg-primary);
    color: var(--text-secondary);
    font: inherit;
    font-weight: 600;
    padding: 0 var(--spacing-sm);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .header-search-btn:hover {
    color: var(--primary-red);
    border-color: var(--primary-red);
    background: var(--primary-red-light);
  }

  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--spacing-sm);
    background: none;
    border: none;
    cursor: pointer;
    margin-left: auto;
  }

  .mobile-menu-btn span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: all var(--transition-base);
  }

  .mobile-menu-btn.open span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .mobile-menu-btn.open span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-btn.open span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .mobile-menu {
    display: none;
    position: absolute;
    top: var(--header-height);
    left: 0;
    right: 0;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-light);
    padding: var(--spacing-lg);
    box-shadow: var(--shadow-md);
  }

  .mobile-menu.open {
    display: block;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .mobile-locale {
    display: grid;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-sm);
  }

  .mobile-search {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
  }

  .mobile-search-input {
    height: 44px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font: inherit;
    padding: 0 var(--spacing-md);
  }

  .mobile-search-input:focus {
    outline: none;
    border-color: var(--primary-red);
    box-shadow: 0 0 0 3px var(--primary-red-light);
  }

  .mobile-search-btn {
    height: 44px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    background: var(--bg-primary);
    color: var(--text-secondary);
    font: inherit;
    padding: 0 var(--spacing-md);
    cursor: pointer;
  }

  .mobile-nav hr {
    border: none;
    border-top: 1px solid var(--border-light);
    margin: var(--spacing-sm) 0;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md);
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .mobile-nav-link:hover {
    background: var(--bg-accent);
    color: var(--primary-red);
  }

  .mobile-nav-link.locale.active {
    background: var(--bg-accent);
    color: var(--text-primary);
    border: 1px solid var(--border-light);
  }

  /* Mobile : parent d'un dropdown plus marqué que les autres items */
  .mobile-nav-link--group {
    font-weight: 600;
    color: var(--text-primary);
  }

  /* Mobile : items enfants indentés et plus discrets */
  .mobile-nav-link--child {
    padding-left: var(--spacing-xl);
    font-size: 0.92rem;
    color: var(--text-secondary);
  }
  .mobile-nav-child-bullet {
    color: var(--text-tertiary);
    margin-right: 4px;
  }

  .external-icon {
    font-size: 0.9rem;
  }

  .nav-external {
    font-size: 0.75rem;
    opacity: 0.6;
  }

  .mobile-cta {
    text-align: center;
    justify-content: center;
    border: 1.5px solid var(--border-medium);
    margin-top: var(--spacing-xs);
  }

  .mobile-cta-primary {
    background: linear-gradient(120deg, var(--primary-red), var(--gold-accent));
    color: var(--text-inverse) !important;
    border-color: transparent;
  }

  .mobile-cta-primary:hover {
    background: linear-gradient(120deg, var(--primary-red-hover), var(--gold-hover));
    color: var(--text-inverse) !important;
  }

  @media (max-width: 1180px) {
    .header-container { gap: var(--spacing-md); }
    .nav-link { padding: 6px 10px; font-size: 0.9rem; }
  }

  @media (max-width: 1080px) {
    /* Hide secondary CTA (Se connecter / Sign in) to keep layout breathable */
    .header-actions .btn-ghost { display: none; }
  }

  @media (max-width: 980px) {
    /* Hide language switch in tight desktop layouts; mobile menu has it */
    .lang-switch { display: none; }
  }

  @media (max-width: 900px) {
    /* À ce niveau on bascule en mobile menu */
    .header-container { justify-content: space-between; }
    .nav, .header-actions { display: none; }
    .mobile-menu-btn { display: flex; }
  }

  @media (max-width: 820px) {
    /* Tablette portrait : logo et padding rétrécis */
    .header-container { padding: 0 var(--spacing-md); gap: var(--spacing-md); }
    .logo-img { height: 44px; }
    .mobile-menu { padding: var(--spacing-md); }
    .mobile-nav-link { padding: 0.7rem 0.85rem; font-size: 0.95rem; }
  }

  @media (max-width: 540px) {
    /* Téléphone : header très compact */
    .header-container { padding: 0 0.85rem; }
    .logo-img { height: 36px; }
    .mobile-menu-btn { padding: 0.45rem; }
    .mobile-menu-btn span { width: 22px; }
    .mobile-search-input,
    .mobile-search-btn { height: 40px; }
    .mobile-nav-link { padding: 0.65rem 0.75rem; font-size: 0.92rem; }
  }

  @media (max-width: 520px) {
    .mobile-search {
      grid-template-columns: 1fr;
    }
  }
</style>
