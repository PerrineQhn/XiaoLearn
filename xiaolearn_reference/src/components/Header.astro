---
import { externalLinks, getMainNav, getCtaLinks } from '../data/navigation';
import { getLocaleSwitchPath, localizePath, type Locale } from '../utils/locale';

interface Props {
  locale?: Locale;
}

const { locale = 'fr' } = Astro.props;
const mainNav = getMainNav(locale);
const ctaLinks = getCtaLinks(locale);

const currentQuery = Astro.url.searchParams.get('q') || '';
const homeHref = localizePath('/', locale);
const searchAction = locale === 'en' ? '/en/dictionnaire' : '/recherche';
const searchLabel = locale === 'en' ? 'Search the website' : 'Rechercher sur le site';
const mobileSearchPlaceholder = locale === 'en' ? 'Search...' : 'Rechercher...';
const mobileSearchButton = locale === 'en' ? 'Search' : 'Rechercher';
const languageSwitchLabel = locale === 'en' ? 'Choose interface language' : "Choisir la langue de l'interface";
const frHref = getLocaleSwitchPath(Astro.url.pathname, 'fr');
const enHref = getLocaleSwitchPath(Astro.url.pathname, 'en');
---

<header class="header">
  <div class="header-container">
    <a href={homeHref} class="logo">
      <img src="/logos/logo_asian-red.png" alt="XiaoLearn" class="logo-img" />
    </a>

    <nav class="nav">
      {mainNav.map(item => (
        <a
          href={item.href}
          class="nav-link"
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener' : undefined}
        >
          {item.label}
          {item.external && <span class="nav-external">↗</span>}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <div class="lang-switch" role="group" aria-label={languageSwitchLabel}>
        <a href={frHref} class={`lang-link ${locale === 'fr' ? 'active' : ''}`}>FR</a>
        <span class="lang-separator">/</span>
        <a href={enHref} class={`lang-link ${locale === 'en' ? 'active' : ''}`}>EN</a>
      </div>
      {ctaLinks.map(cta => (
        <a
          href={cta.href}
          class={`btn btn-sm ${cta.variant === 'primary' ? 'btn-primary' : 'btn-ghost'}`}
        >
          {cta.label}
        </a>
      ))}
      {externalLinks.map(link => (
        <a
          href={link.href}
          class="btn btn-sm btn-secondary"
          target="_blank"
          rel="noopener"
        >
          {link.label}
        </a>
      ))}
    </div>

    <button class="mobile-menu-btn" aria-label="Menu" id="mobile-menu-btn">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu">
    <form class="mobile-search" action={searchAction} method="get" role="search">
      <label for="mobile-search-input" class="visually-hidden">{searchLabel}</label>
      <input
        id="mobile-search-input"
        class="mobile-search-input"
        type="search"
        name="q"
        value={currentQuery}
        placeholder={mobileSearchPlaceholder}
      />
      <button type="submit" class="mobile-search-btn">{mobileSearchButton}</button>
    </form>

    <div class="mobile-locale">
      <a href={frHref} class={`mobile-nav-link locale ${locale === 'fr' ? 'active' : ''}`}>Francais (FR)</a>
      <a href={enHref} class={`mobile-nav-link locale ${locale === 'en' ? 'active' : ''}`}>English (EN)</a>
    </div>

    <nav class="mobile-nav">
      {mainNav.map(item => (
        <a
          href={item.href}
          class="mobile-nav-link"
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener' : undefined}
        >
          {item.label}
          {item.external && <span class="external-icon">↗</span>}
        </a>
      ))}
      <hr />
      {ctaLinks.map(cta => (
        <a
          href={cta.href}
          class={`mobile-nav-link mobile-cta ${cta.variant === 'primary' ? 'mobile-cta-primary' : ''}`}
        >
          {cta.label}
        </a>
      ))}
      {externalLinks.length > 0 && (
        <>
          <hr />
          {externalLinks.map(link => (
            <a
              href={link.href}
              class="mobile-nav-link external"
              target="_blank"
              rel="noopener"
            >
              {link.label}
              <span class="external-icon">↗</span>
            </a>
          ))}
        </>
      )}
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
    menuBtn.classList.toggle('open');
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-primary);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-light);
    height: var(--header-height);
  }

  .header-container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
    height: 100%;
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-shrink: 0;
  }

  .logo-img {
    height: 38px;
    width: auto;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    justify-content: center;
    min-width: 0;
  }

  .nav-link {
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-secondary);
    padding: 8px 14px;
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--primary-red);
    background: var(--primary-red-light);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-shrink: 0;
  }

  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
  }

  .lang-link {
    color: var(--text-tertiary);
    font-weight: 600;
    font-size: 0.8rem;
    line-height: 1;
    transition: color var(--transition-fast);
  }

  .lang-link:hover {
    color: var(--primary-red);
  }

  .lang-link.active {
    color: var(--text-primary);
  }

  .lang-separator {
    color: var(--text-tertiary);
    font-size: 0.72rem;
    line-height: 1;
  }

  .header-search {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--spacing-xs);
    align-items: center;
    justify-self: end;
    width: min(100%, 310px);
  }

  .header-search-input {
    height: 40px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font: inherit;
    padding: 0 var(--spacing-md);
    min-width: 0;
  }

  .header-search-input:focus {
    outline: none;
    border-color: var(--primary-red);
    box-shadow: 0 0 0 3px var(--primary-red-light);
  }

  .header-search-input::placeholder {
    color: var(--text-tertiary);
  }

  .header-search-btn {
    height: 40px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    background: var(--bg-primary);
    color: var(--text-secondary);
    font: inherit;
    font-weight: 600;
    padding: 0 var(--spacing-sm);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .header-search-btn:hover {
    color: var(--primary-red);
    border-color: var(--primary-red);
    background: var(--primary-red-light);
  }

  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--spacing-sm);
    background: none;
    border: none;
    cursor: pointer;
    margin-left: auto;
  }

  .mobile-menu-btn span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: all var(--transition-base);
  }

  .mobile-menu-btn.open span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .mobile-menu-btn.open span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-btn.open span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .mobile-menu {
    display: none;
    position: absolute;
    top: var(--header-height);
    left: 0;
    right: 0;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-light);
    padding: var(--spacing-lg);
    box-shadow: var(--shadow-md);
  }

  .mobile-menu.open {
    display: block;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .mobile-locale {
    display: grid;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-sm);
  }

  .mobile-search {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
  }

  .mobile-search-input {
    height: 44px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font: inherit;
    padding: 0 var(--spacing-md);
  }

  .mobile-search-input:focus {
    outline: none;
    border-color: var(--primary-red);
    box-shadow: 0 0 0 3px var(--primary-red-light);
  }

  .mobile-search-btn {
    height: 44px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    background: var(--bg-primary);
    color: var(--text-secondary);
    font: inherit;
    padding: 0 var(--spacing-md);
    cursor: pointer;
  }

  .mobile-nav hr {
    border: none;
    border-top: 1px solid var(--border-light);
    margin: var(--spacing-sm) 0;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md);
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .mobile-nav-link:hover {
    background: var(--bg-accent);
    color: var(--primary-red);
  }

  .mobile-nav-link.locale.active {
    background: var(--bg-accent);
    color: var(--text-primary);
    border: 1px solid var(--border-light);
  }

  .external-icon {
    font-size: 0.9rem;
  }

  .nav-external {
    font-size: 0.75rem;
    opacity: 0.6;
  }

  .mobile-cta {
    text-align: center;
    justify-content: center;
    border: 1.5px solid var(--border-medium);
    margin-top: var(--spacing-xs);
  }

  .mobile-cta-primary {
    background: linear-gradient(120deg, var(--primary-red), var(--gold-accent));
    color: var(--text-inverse) !important;
    border-color: transparent;
  }

  .mobile-cta-primary:hover {
    background: linear-gradient(120deg, var(--primary-red-hover), var(--gold-hover));
    color: var(--text-inverse) !important;
  }

  @media (max-width: 1180px) {
    .header-container { gap: var(--spacing-md); }
    .nav-link { padding: 6px 10px; font-size: 0.9rem; }
  }

  @media (max-width: 1080px) {
    /* Hide secondary CTA (Se connecter / Sign in) to keep layout breathable */
    .header-actions .btn-ghost { display: none; }
  }

  @media (max-width: 980px) {
    /* Hide language switch in tight desktop layouts; mobile menu has it */
    .lang-switch { display: none; }
  }

  @media (max-width: 900px) {
    .header-container { justify-content: space-between; }
    .nav, .header-actions { display: none; }
    .mobile-menu-btn { display: flex; }
  }

  @media (max-width: 520px) {
    .mobile-search {
      grid-template-columns: 1fr;
    }
  }
</style>
