---
import type { HSKEntry } from '../types/hsk';
import HSKLevelBadge from './HSKLevelBadge.astro';
import { localizePath, type Locale } from '../utils/locale';

interface Props {
  entry: HSKEntry;
  showLevel?: boolean;
  href?: string | null;
  locale?: Locale;
}

const { entry, showLevel = true, href, locale = 'fr' } = Astro.props;
const baseHref = entry.level === 'hors-hsk'
  ? `/dictionnaire/hors-hsk/${entry.id}`
  : `/dictionnaire/${entry.id}`;
const defaultHref = localizePath(baseHref, locale);
const targetHref = href === undefined ? defaultHref : href;
const displayTranslation = locale === 'en'
  ? (entry.translationEn || entry.translation || entry.translationFr)
  : (entry.translationFr || entry.translationEn || entry.translation || '');
---

{targetHref ? (
  <a href={targetHref} class="character-card">
    <div class="card-header">
      <span class="hanzi">{entry.hanzi}</span>
      {showLevel && <HSKLevelBadge level={entry.level} size="sm" />}
    </div>

    <div class="card-body">
      <span class="pinyin">{entry.pinyin}</span>
      <p class="translation">{displayTranslation}</p>
    </div>

    <div class="card-footer">
      <span class="category">{entry.category}</span>
      <span class="arrow">→</span>
    </div>
  </a>
) : (
  <article class="character-card static-card">
    <div class="card-header">
      <span class="hanzi">{entry.hanzi}</span>
      {showLevel && <HSKLevelBadge level={entry.level} size="sm" />}
    </div>

    <div class="card-body">
      <span class="pinyin">{entry.pinyin}</span>
      <p class="translation">{displayTranslation}</p>
    </div>

    <div class="card-footer">
      <span class="category">{entry.category}</span>
    </div>
  </article>
)}

<style>
  .character-card {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-lg);
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-light);
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
  }

  .character-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary-red-light);
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--spacing-sm);
  }

  .hanzi {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    line-height: 1;
    color: var(--text-primary);
  }

  .card-body {
    flex: 1;
  }

  .pinyin {
    display: block;
    font-style: italic;
    color: var(--jade-green);
    margin-bottom: var(--spacing-xs);
  }

  .translation {
    font-size: 0.95rem;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--spacing-md);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--border-light);
  }

  .category {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    text-transform: capitalize;
  }

  .arrow {
    color: var(--primary-red);
    opacity: 0;
    transform: translateX(-8px);
    transition: all var(--transition-base);
  }

  .character-card:hover .arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .static-card:hover {
    transform: none;
    box-shadow: var(--shadow-sm);
    border-color: var(--border-light);
  }
</style>
